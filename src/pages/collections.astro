---
import PhotoBall2 from '../components/PhotoBall2.astro';

const collectionCards = [
  { title: "Interview", description: "Conversations and behind-the-scenes stories." },
  { title: "Music Videos", description: "Editorial and campaign photography highlights." },
  { title: "Shortfilm", description: "Narrative-driven short format productions." },
  { title: "Ads", description: "Commercial concepts crafted for audience impact." }
];
---

<section class="collections-wrapper">
  <div class="collections-inner">
    <p class="collections-kicker">Collections</p>
    <h2 class="collections-heading">Config Driven Categories</h2>

    <div class="collections-grid">
      {collectionCards.map((card) => (
        <article class="collection-card" data-collection-card>
          <span class="collection-cursor" aria-hidden="true"></span>
          <PhotoBall2 />
          <h3>{card.title}</h3>
          <p>{card.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  (() => {
    const cards = document.querySelectorAll('[data-collection-card]:not([data-cursor-ready])');
    if (!cards.length) return;

    cards.forEach((node) => {
      if (!(node instanceof HTMLElement)) return;
      const card = node;
      card.setAttribute('data-cursor-ready', 'true');
      const cursor = card.querySelector('.collection-cursor');
      if (!cursor) return;

      const updateCursor = (event: MouseEvent) => {
        const rect = card.getBoundingClientRect();
        const x = event.clientX - rect.left;
        const y = event.clientY - rect.top;
        card.style.setProperty('--cursor-x', `${x}px`);
        card.style.setProperty('--cursor-y', `${y}px`);
      };

      card.addEventListener('mouseenter', (event: MouseEvent) => {
        updateCursor(event);
        card.classList.add('is-cursor-active');
      });

      card.addEventListener('mousemove', updateCursor);
      card.addEventListener('mouseleave', () => {
        card.classList.remove('is-cursor-active');
      });
    });
  })();
</script>

<style>
  .collections-wrapper {
    background: #111;
    padding: 80px 16px;
  }

  .collections-inner {
    width: min(1120px, 100%);
    margin: 0 auto;
  }

  .collections-kicker {
    color: #a3a3a3;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.8rem;
    margin-bottom: 8px;
  }

  .collections-heading {
    color: #f5f5f5;
    margin: 0 0 28px 0;
    font-size: clamp(1.8rem, 3vw, 2.6rem);
  }

  .collections-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .collection-card {
    cursor: pointer;
    position: relative;
    z-index: 0;
    isolation: isolate;
    overflow: visible;
    border: 1px solid rgba(255, 255, 255, 0.16);
    background: linear-gradient(165deg, #1a1a1a 0%, #121212 100%);
    border-radius: 14px;
    padding: 20px;
    min-height: 160px;
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
    --cursor-x: 50%;
    --cursor-y: 50%;
  }

  .collection-card:hover {
    cursor: none;
    transform: translateY(-4px);
    z-index: 30;
    border-color: rgba(255, 255, 255, 0.35);
    box-shadow: 0 16px 38px rgba(0, 0, 0, 0.35);
  }

  .collection-card:focus-within {
    z-index: 30;
  }

  .collection-card h3 {
    position: relative;
    z-index: 2;
    color: #fff;
    margin: 0 0 8px 0;
    font-size: 1.2rem;
  }

  .collection-card p {
    position: relative;
    z-index: 2;
    color: #bdbdbd;
    margin: 0;
    line-height: 1.5;
    font-size: 0.95rem;
  }

  .collection-cursor {
    position: absolute;
    left: 0;
    top: 0;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    pointer-events: none;
    z-index: 3;
    opacity: 0;
    transform: translate(calc(var(--cursor-x) - 50%), calc(var(--cursor-y) - 50%)) scale(0.85);
    background: rgba(182, 182, 182, 0.589);
    /* border: 1px solid rgba(230, 230, 230, 0.55); */
    transition: opacity 0.18s ease, transform 0.18s ease;
    backdrop-filter: blur(1px);
  }

  .collection-card.is-cursor-active .collection-cursor {
    opacity: 1;
    transform: translate(calc(var(--cursor-x) - 50%), calc(var(--cursor-y) - 50%)) scale(1);
  }

  @media (max-width: 960px) {
    .collections-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .collections-wrapper {
      padding: 56px 16px;
    }

    .collections-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
