---
export interface Props {
  modelPath: string;
  title?: string;
  description?: string;
  width?: string;
  height?: string;
}

const { 
  modelPath, 
  title = "3D Model", 
  description = "Interactive 3D model",
  width = "100%",
  height = "100vh"
} = Astro.props;
---

<!-- Scroll spacer: 400vh height creates scroll distance -->
<div class="model-scroll-section" id="model-scroll-section">
  <!-- Fixed/sticky container that stays centered -->
  <div class="model-viewer-container">
    <!-- Visual indicator (optional - for testing) -->
    <div class="center-indicator"></div>
    
    <model-viewer
      src={modelPath}
      alt={title}
      camera-controls="false"
      touch-action="none"
      shadow-intensity="0.3"
      environment-image="neutral"
      interpolation-decay="200"
      min-camera-orbit="-Infinity -Infinity auto"
      max-camera-orbit="Infinity Infinity Infinity"
      min-field-of-view="10deg"
      max-field-of-view="180deg"
      style="width: 100%; height: 100%; background-color: transparent;"
      id="scroll-model"
      loading="eager"
      data-capture-mode="false"
    >
      <div class="progress-bar hide" slot="progress-bar">
        <div class="update-bar"></div>
      </div>
    </model-viewer>
    
    <!-- Scroll progress indicator -->
    <div class="scroll-progress-indicator"></div>
  </div>

  <div class="keyframe-text-block" id="keyframe-text-block">
    <p>
      <span class="keyframe-word">Passionate</span>
      <span class="keyframe-word">visual</span>
      <span class="keyframe-word">storyteller</span>
      <span class="keyframe-word">who</span>
      <span class="keyframe-word">specializes</span>
      <span class="keyframe-word">in</span>
      <span class="keyframe-word">shooting</span>
      <span class="keyframe-word">and</span>
      <span class="keyframe-word">editing</span>
      <span class="keyframe-word">compelling</span>
      <span class="keyframe-word">content.</span>
      <span class="keyframe-word">With</span>
      <span class="keyframe-word">an</span>
      <span class="keyframe-word">eye</span>
      <span class="keyframe-word">for</span>
      <span class="keyframe-word">detail</span>
      <span class="keyframe-word">and</span>
      <span class="keyframe-word">a</span>
      <span class="keyframe-word">dedication</span>
      <span class="keyframe-word">to</span>
      <span class="keyframe-word">crafting</span>
      <span class="keyframe-word">cinematic</span>
      <span class="keyframe-word">experiences,</span>
      <span class="keyframe-word">Aniket</span>
      <span class="keyframe-word">brings</span>
      <span class="keyframe-word">stories</span>
      <span class="keyframe-word">to</span>
      <span class="keyframe-word">life</span>
      <span class="keyframe-word">through</span>
      <span class="keyframe-word">the</span>
      <span class="keyframe-word">lens</span>
      <span class="keyframe-word">and</span>
      <span class="keyframe-word">the</span>
      <span class="keyframe-word">editing</span>
      <span class="keyframe-word">suite.</span>
    </p>
  </div>
  
  <!-- About content overlay - appears in second half of section -->
  <div class="about-content-container" id="about-content" style="z-index: -1; opacity: 0;">
    <div class="floating-items-layer">
      <div class="floating-image floating-image-1" style="--translate-x: 120vw; --translate-y: 100vh; --scale: 0.3; --opacity: 0;">
        <img src="/coldplay.jpg" alt="Coldplay" />
      </div>
      <div class="floating-image floating-image-2" style="--translate-x: 120vw; --translate-y: 100vh; --scale: 0.3; --opacity: 0;">
        <img src="/bryan-adams.png" alt="Bryan Adams" />
      </div>
      <div class="floating-image floating-image-3" style="--translate-x: 120vw; --translate-y: 100vh; --scale: 0.3; --opacity: 0;">
        <img src="/Fisher.jpg" alt="Fisher" />
      </div>
      <div class="floating-image floating-image-4" style="--translate-x: 120vw; --translate-y: 100vh; --scale: 0.3; --opacity: 0;">
        <img src="/anjunadeep.jpg" alt="Anjunadeep" />
      </div>
      <div class="floating-image floating-image-5" style="--translate-x: 120vw; --translate-y: 100vh; --scale: 0.3; --opacity: 0;">
        <img src="/BenBohmer.jpg" alt="Ben Bohmer" />
      </div>
      <div class="floating-image floating-image-6" style="--translate-x: 120vw; --translate-y: 100vh; --scale: 0.3; --opacity: 0;">
        <img src="/klang.jpg" alt="Klang" />
      </div>
    </div>

    <!-- <div class="about-text">
      <p class="text-lg md:text-3xl max-w-3xl px-8 leading-relaxed">
        <span class="about-text-highlight" style="--highlight-progress: 0%;">A passionate visual storyteller who specializes in shooting and editing expressive content. 
        With an eye for detail and a dedication to crafting cinematic experiences, Aniket brings 
        stories to life through the lens and the editing suite.</span>
      </p>
    </div> -->
  </div>
</div>

<script type="module" src="https://unpkg.com/@google/model-viewer/dist/model-viewer.min.js"></script>

<script>
  // @ts-nocheck
  
  // Optimized model viewer with scroll-based camera animation
  async function initModelViewer() {
    // Wait for the model-viewer custom element to be defined
    if (!customElements.get('model-viewer')) {
      await customElements.whenDefined('model-viewer');  
    }
    
    const modelViewer = document.getElementById('scroll-model') as any;
    
    if (!modelViewer) {
      console.error('ModelViewer element not found');
      return;
    }
    
    // Disable manual camera controls
    modelViewer.cameraControls = false;
    
    // Wait for model to load
    modelViewer.addEventListener('load', () => {
      // Define camera positions for scroll animation
      // NOTE: Playback is reversed — progress=1 (section start) maps to LAST element,
      // progress=0 (section end) maps to FIRST element.
      // Captured hold pose is repeated at the END so the model stays there initially.
      const modelPositions = [
        // Earlier frames (reached later in reversed playback)
        { cameraOrbit: "0deg 75deg 35m",   fieldOfView: "45deg", scale: 0.70, translateXvw: -70 },
        { cameraOrbit: "15deg 75deg 32m",  fieldOfView: "45deg", scale: 0.76, translateXvw: -40 },
        { cameraOrbit: "30deg 75deg 29m",  fieldOfView: "45deg", scale: 0.83, translateXvw: -35 },
        { cameraOrbit: "45deg 75deg 26m",  fieldOfView: "45deg", scale: 0.92, translateXvw: -30 },
        { cameraOrbit: "60deg 75deg 23m",  fieldOfView: "45deg", scale: 1.03, translateXvw: -24 },
        { cameraOrbit: "75deg 75deg 21m",  fieldOfView: "45deg", scale: 1.18, translateXvw: -17 },
        { cameraOrbit: "90deg 75deg 10m",  fieldOfView: "70deg", scale: 1.35, translateXvw: -12},
        { cameraOrbit: "122deg 14deg 15m", fieldOfView: "48.5deg", scale: 1.50, translateXvw: -10 },
        { cameraOrbit: "126deg 30deg 16m", fieldOfView: "47deg", scale: 1.62, translateXvw: -9 },
        { cameraOrbit: "129deg 44deg 16.5m", fieldOfView: "45.5deg", scale: 1.74, translateXvw: -6 },
        { cameraOrbit: "132deg 58deg 17m", fieldOfView: "44deg", scale: 1.86, translateXvw: -4 },

        // 2nd pose hold
        { cameraOrbit: "135deg 80deg 17m", fieldOfView: "42deg", scale: 1.85, translateXvw: -5 },
        { cameraOrbit: "135deg 80deg 17m", fieldOfView: "42deg", scale: 1.65, translateXvw: 6 },
        { cameraOrbit: "135deg 80deg 17m", fieldOfView: "42deg", scale: 1.40, translateXvw: 10 },
        { cameraOrbit: "135deg 80deg 17m", fieldOfView: "42deg", scale: 1.20, translateXvw: 18 },
        { cameraOrbit: "135deg 80deg 17m", fieldOfView: "42deg", scale: 1.00, translateXvw: 22 },
        { cameraOrbit: "135deg 80deg 17m", fieldOfView: "42deg", scale: 1.20, translateXvw: 22 },
        { cameraOrbit: "135deg 80deg 17m", fieldOfView: "42deg", scale: 1.40, translateXvw: 22 },
        { cameraOrbit: "135deg 80deg 17m", fieldOfView: "42deg", scale: 1.60, translateXvw: 22 },
        { cameraOrbit: "135deg 80deg 17m", fieldOfView: "42deg", scale: 1.80, translateXvw: 22 },
        { cameraOrbit: "135deg 80deg 17m", fieldOfView: "42deg", scale: 1.80, translateXvw: 22 },
        { cameraOrbit: "135deg 80deg 17m", fieldOfView: "42deg", scale: 1.80, translateXvw: 22 },
        { cameraOrbit: "135deg 80deg 17m", fieldOfView: "42deg", scale: 1.60, translateXvw: 22 },
        { cameraOrbit: "135deg 80deg 17m", fieldOfView: "42deg", scale: 1.40, translateXvw: 22 },
        // { cameraOrbit: "135deg 80deg 17m", fieldOfView: "42deg", scale: 1.20, translateXvw: 22 },
        { cameraOrbit: "135deg 80deg 17m", fieldOfView: "42deg", scale: 1.20, translateXvw: 18 },
        { cameraOrbit: "135deg 80deg 17m", fieldOfView: "42deg", scale: 1.40, translateXvw: 10 },
        { cameraOrbit: "135deg 80deg 17m", fieldOfView: "42deg", scale: 1.65, translateXvw: 6 },
        { cameraOrbit: "135deg 80deg 17m", fieldOfView: "42deg", scale: 1.85, translateXvw: -1 },

        // Small exit from hold, then initial visible pose (last keyframe)
        { cameraOrbit: "129deg 44deg 16.5m", fieldOfView: "45.5deg", scale: 1.92, translateXvw: -2 },
        { cameraOrbit: "132deg 58deg 17m", fieldOfView: "44deg", scale: 1.96, translateXvw: -1 },
        { cameraOrbit: "90deg 120deg 17m", fieldOfView: "42deg", scale: 2.00, translateXvw: 0 },
      ];
      
      let currentScrollProgress = 1;
      let targetScrollProgress = 1;
      let capturedPositions = [];
      let captureMode = false;
      let animationFrameId = null;
      let targetScale = 2;
      let currentScale = 2;
      let targetTranslateX = 0;
      let currentTranslateX = 0;
      let currentSectionProgress = 0;
      let targetSectionProgress = 0;
      const leftTextWindowStartIndex = 15;
      const leftTextWindowEndIndex = 23;
      // Initial pose is driven by the LAST element of modelPositions
      // (because playback is reversed: progress=1 at section start -> last keyframe).
      const initialHoldPose = {
        cameraOrbit: modelPositions[modelPositions.length - 1].cameraOrbit,
        fieldOfView: modelPositions[modelPositions.length - 1].fieldOfView,
        scale: modelPositions[modelPositions.length - 1].scale,
        translateXvw: modelPositions[modelPositions.length - 1].translateXvw
      };
      
      function applyContainerTransform() {
        if (modelContainer) {
          modelContainer.style.transform = `translate3d(${currentTranslateX}vw, 0, 0) scale(${currentScale})`;
        }
      }
      
      function applyInitialHoldPose() {
        currentScrollProgress = 1;
        targetScrollProgress = 1;
        currentSectionProgress = 0;
        targetSectionProgress = 0;
        currentScale = initialHoldPose.scale;
        targetScale = initialHoldPose.scale;
        currentTranslateX = initialHoldPose.translateXvw;
        targetTranslateX = initialHoldPose.translateXvw;
        modelViewer.cameraOrbit = initialHoldPose.cameraOrbit;
        modelViewer.fieldOfView = initialHoldPose.fieldOfView;
        applyContainerTransform();
        window.__modelTranslateXvw = currentTranslateX;
      }
      
      // Get visual indicators
      const centerIndicator = document.querySelector('.center-indicator');
      const progressIndicator = document.querySelector('.scroll-progress-indicator');
      const modelContainer = document.querySelector('.model-viewer-container');
      const keyframeTextBlock = document.getElementById('keyframe-text-block');
      const keyframeWords = Array.from(
        keyframeTextBlock?.querySelectorAll('.keyframe-word') || []
      ) as HTMLElement[];

      function updateKeyframeWordHighlight(positionIndex: number) {
        if (!keyframeWords.length) return;

        const windowSpan = Math.max(leftTextWindowEndIndex - leftTextWindowStartIndex, 0.0001);
        const highlightProgress = Math.min(
          Math.max((leftTextWindowEndIndex - positionIndex) / windowSpan, 0),
          1
        );
        const highlightedWords = Math.floor(highlightProgress * keyframeWords.length);

        keyframeWords.forEach((word, index) => {
          word.classList.toggle('is-highlighted', index < highlightedWords);
        });
      }
      
      // Create debug overlay
      const debugOverlay = document.createElement('div');
      debugOverlay.id = 'model-debug-overlay';
      debugOverlay.style.cssText = `
        position: fixed;
        top: 10px;
        right: 10px;
        background: rgba(0, 0, 0, 0.8);
        color: #0f0;
        padding: 15px;
        font-family: monospace;
        font-size: 12px;
        border-radius: 5px;
        z-index: 10000;
        max-width: 300px;
        display: none;
      `;
      document.body.appendChild(debugOverlay);
      
      // Smooth camera and scale update function with interpolation
      function updateCameraAndScale() {
        animationFrameId = null;
        
        if (!modelViewer?.loaded) {
          return;
        }
        
        // Keep animation responsive to scroll while still smooth.
        const progressLerpFactor = 0.28;
        const maxScrollStepPerFrame = 0.04;
        const maxSectionStepPerFrame = 0.04;
        
        const scrollStep = (targetScrollProgress - currentScrollProgress) * progressLerpFactor;
        const sectionStep = (targetSectionProgress - currentSectionProgress) * progressLerpFactor;
        
        currentScrollProgress += Math.sign(scrollStep) * Math.min(Math.abs(scrollStep), maxScrollStepPerFrame);
        currentSectionProgress += Math.sign(sectionStep) * Math.min(Math.abs(sectionStep), maxSectionStepPerFrame);
        
        if (Math.abs(targetScrollProgress - currentScrollProgress) < 0.0005) {
          currentScrollProgress = targetScrollProgress;
        }
        if (Math.abs(targetSectionProgress - currentSectionProgress) < 0.0005) {
          currentSectionProgress = targetSectionProgress;
        }
        
        // Calculate interpolation between positions
        const positionIndex = currentScrollProgress * (modelPositions.length - 1);
        const currentIndex = Math.floor(positionIndex);
        const nextIndex = Math.min(currentIndex + 1, modelPositions.length - 1);
        const t = positionIndex - currentIndex;

        if (keyframeTextBlock) {
          const showKeyframeText =
            positionIndex >= leftTextWindowStartIndex &&
            positionIndex <= leftTextWindowEndIndex;
          keyframeTextBlock.classList.toggle('is-visible', showKeyframeText);
        }
        updateKeyframeWordHighlight(positionIndex);

        // Smoothstep between keyframes for buttery in/out transitions.
        const easedT = t * t * (3 - 2 * t);
        
        const current = modelPositions[currentIndex];
        const next = modelPositions[nextIndex];
        
        // Interpolate camera values
        const interpolatedOrbit = interpolateCameraOrbit(current.cameraOrbit, next.cameraOrbit, easedT);
        const interpolatedFOV = interpolateFOV(current.fieldOfView, next.fieldOfView, easedT);
        
        // Apply camera changes
        modelViewer.cameraOrbit = interpolatedOrbit;
        modelViewer.fieldOfView = interpolatedFOV;
        
        // Interpolate per-keyframe transform values (Option 1).
        targetScale = current.scale + (next.scale - current.scale) * easedT;
        targetTranslateX = current.translateXvw + (next.translateXvw - current.translateXvw) * easedT;
        
        // Very low lerp factors for heavy delayed transform motion.
        const scaleLerpFactor = 0.045;
        const translateLerpFactor = 0.04;
        currentScale += (targetScale - currentScale) * scaleLerpFactor;
        currentTranslateX += (targetTranslateX - currentTranslateX) * translateLerpFactor;
        
        // Apply smoothly interpolated translate + scale to the container
        applyContainerTransform();
        window.__modelTranslateXvw = currentTranslateX;
        
        // Debug: log camera changes
        if (window.debugScrollAnimation) {
          console.log('Camera Update:', {
            progress: currentScrollProgress.toFixed(3),
            orbit: interpolatedOrbit,
            fov: interpolatedFOV,
            targetScale: targetScale.toFixed(3),
            currentScale: currentScale.toFixed(3),
            targetTranslateX: `${targetTranslateX.toFixed(2)}vw`,
            currentTranslateX: `${currentTranslateX.toFixed(2)}vw`
          });
        }
        
        // Update debug overlay
        updateDebugOverlay();
        
        // Continue animation loop while there is pending progress or transform interpolation
        const hasProgressDelta =
          Math.abs(targetScrollProgress - currentScrollProgress) > 0.0005 ||
          Math.abs(targetSectionProgress - currentSectionProgress) > 0.0005;
        const hasTransformDelta =
          Math.abs(targetScale - currentScale) > 0.001 ||
          Math.abs(targetTranslateX - currentTranslateX) > 0.01;
        
        if ((hasProgressDelta || hasTransformDelta) && !captureMode) {
          animationFrameId = requestAnimationFrame(updateCameraAndScale);
        }
      }
      
      // Update debug overlay with current position info
      function updateDebugOverlay() {
        const scrollPercent = (currentScrollProgress * 100).toFixed(2);
        const scrollPixels = Math.round(window.pageYOffset || document.documentElement.scrollTop);
        const modeColor = captureMode ? '#ff0' : '#0f0';
        const modeStatus = captureMode ? '🎥 CAPTURE MODE ON' : '▶️ PLAYBACK MODE';
        
        debugOverlay.style.borderColor = modeColor;
        debugOverlay.innerHTML = `
          <strong style="color: ${modeColor}">${modeStatus}</strong><br>
          <hr style="margin: 5px 0; border-color: ${modeColor};">
          Scroll: ${scrollPercent}%<br>
          Pixels: ${scrollPixels}px<br>
          Target Scale: ${targetScale.toFixed(3)}<br>
          Current Scale: ${currentScale.toFixed(3)}<br>
          Target X: ${targetTranslateX.toFixed(2)}vw<br>
          Current X: ${currentTranslateX.toFixed(2)}vw<br>
          <hr style="margin: 5px 0; border-color: ${modeColor};">
          Camera Orbit: ${modelViewer.cameraOrbit}<br>
          Field of View: ${modelViewer.fieldOfView}<br>
          <hr style="margin: 5px 0; border-color: ${modeColor};">
          <small>Press 'M' to toggle capture mode<br>
          Press 'C' to capture position<br>
          Move X: Arrow Left/Right or A/D<br>
          Scale: Arrow Up/Down or +/-<br>
          Press 'D' to toggle debug<br>
          Press 'P' to print captured<br>
          Press 'X' to clear captured</small>
        `;
      }
      
      // Parse and interpolate camera orbit
      function interpolateCameraOrbit(orbit1: string, orbit2: string, t: number) {
        const parseOrbit = (orbit: string) => {
          const parts = orbit.split(' ');
          return {
            theta: parseFloat(parts[0]),
            phi: parseFloat(parts[1]),
            radius: parseFloat(parts[2])
          };
        };
        
        const pos1 = parseOrbit(orbit1);
        const pos2 = parseOrbit(orbit2);
        
        const theta = pos1.theta + (pos2.theta - pos1.theta) * t;
        const phi = pos1.phi + (pos2.phi - pos1.phi) * t;
        const radius = pos1.radius + (pos2.radius - pos1.radius) * t;
        
        return `${theta}deg ${phi}deg ${radius}m`;
      }
      
      // Interpolate field of view
      function interpolateFOV(fov1: string, fov2: string, t: number) {
        const val1 = parseFloat(fov1);
        const val2 = parseFloat(fov2);
        const interpolated = val1 + (val2 - val1) * t;
        return `${interpolated}deg`;
      }
      
      // Capture current position
      function capturePosition() {
        // Warn if not in capture mode
        if (!captureMode) {
          console.warn('⚠️ WARNING: Not in Capture Mode! Press "M" first to enable manual camera controls.');
        }
        
        const position = {
          scrollProgress: currentScrollProgress,
          scrollPercent: (currentScrollProgress * 100).toFixed(2) + '%',
          scrollPixels: Math.round(window.pageYOffset || document.documentElement.scrollTop),
          cameraOrbit: modelViewer.cameraOrbit,
          fieldOfView: modelViewer.fieldOfView,
          scale: Number(currentScale.toFixed(3)),
          translateXvw: Number(currentTranslateX.toFixed(2)),
          mode: captureMode ? 'CAPTURE' : 'PLAYBACK'
        };
        
        capturedPositions.push(position);
        
        console.log(`📸 Position Captured! (${capturedPositions.length} total)`);
        console.log('═══════════════════════════════════════');
        console.log(`Mode: ${position.mode} ${!captureMode ? '⚠️' : '✓'}`);
        console.log(`Scroll Progress: ${position.scrollPercent} (${position.scrollProgress.toFixed(4)})`);
        console.log(`Scroll Pixels: ${position.scrollPixels}px`);
        console.log(`Camera Orbit: ${position.cameraOrbit}`);
        console.log(`Field of View: ${position.fieldOfView}`);
        console.log(`Scale: ${position.scale}`);
        console.log(`Translate X: ${position.translateXvw}vw`);
        console.log('═══════════════════════════════════════\n');
        
        // Visual feedback
        const feedback = document.createElement('div');
        feedback.textContent = '📸 Position Captured!';
        feedback.style.cssText = `
          position: fixed;
          top: 50%;
          left: 50%;
          transform: translate(-50%, -50%);
          background: rgba(0, 255, 0, 0.9);
          color: black;
          padding: 20px 40px;
          font-size: 18px;
          font-weight: bold;
          border-radius: 10px;
          z-index: 10001;
          // animation: fadeOut 1s forwards;
        `;
        document.body.appendChild(feedback);
        setTimeout(() => feedback.remove(), 1000);
      }
      
      // Print all captured positions
      function printCapturedPositions() {
        if (capturedPositions.length === 0) {
          console.log('No positions captured yet. Press "C" to capture positions.');
          return;
        }
        
        console.log('\n🎬 CAPTURED POSITIONS ARRAY');
        console.log('═══════════════════════════════════════');
        console.log('Copy this array to use in your code:\n');
        console.log('const modelPositions = [');
        capturedPositions.forEach((pos, index) => {
          console.log(`  { // Position ${index + 1} - Scroll: ${pos.scrollPercent}`);
          console.log(`    cameraOrbit: "${pos.cameraOrbit}",`);
          console.log(`    fieldOfView: "${pos.fieldOfView}"`);
          console.log(`  }${index < capturedPositions.length - 1 ? ',' : ''}`);
        });
        console.log('];\n');
        console.log('const transformKeyframes = [');
        capturedPositions.forEach((pos, index) => {
          console.log(`  { scale: ${pos.scale}, translateXvw: ${pos.translateXvw} }${index < capturedPositions.length - 1 ? ',' : ''}`);
        });
        console.log('];\n');
        console.log('═══════════════════════════════════════\n');
        
        // Also log as JSON for easy copying
        console.log('JSON Format:');
        console.log(JSON.stringify(capturedPositions, null, 2));
      }
      
      // Toggle capture mode
      function toggleCaptureMode() {
        captureMode = !captureMode;
        
        if (captureMode) {
          // Freeze current transform values so you can nudge from exact live pose.
          targetScale = currentScale;
          targetTranslateX = currentTranslateX;
          
          // Enable camera controls for manual positioning
          modelViewer.cameraControls = true;
          modelViewer.setAttribute('touch-action', 'pan-y');
          
          // Disable interpolation for immediate camera response
          modelViewer.interpolationDecay = 0;
          
          // Get current camera position to prevent jumping
          const currentOrbit = modelViewer.getCameraOrbit();
          const currentFOV = modelViewer.getFieldOfView();
          
          console.log('🎥 CAPTURE MODE ENABLED');
          console.log('═══════════════════════════════════════');
          console.log('You can now manually control the camera:');
          console.log('- Drag to rotate');
          console.log('- Scroll wheel to zoom');
          console.log('- Right-click drag to pan');
          console.log('- Two-finger drag to pan (mobile)');
          console.log('- Move X: Arrow Left/Right or A/D (also , / .)');
          console.log('- Scale: Arrow Up/Down or +/- (also [ / ])');
          console.log('- Hold Shift with those keys for fine adjustments');
          console.log('Scroll to different positions and press "C" to capture');
          console.log('═══════════════════════════════════════\n');
        } else {
          // Disable camera controls and resume scroll animation
          modelViewer.cameraControls = false;
          modelViewer.setAttribute('touch-action', 'none');
          
          // Re-enable interpolation for smooth animation
          modelViewer.interpolationDecay = 200;
          
          console.log('▶️ PLAYBACK MODE ENABLED');
          console.log('═══════════════════════════════════════');
          console.log('Scroll animation is now active');
          console.log('═══════════════════════════════════════\n');
        }
        
        // Show visual feedback
        const feedback = document.createElement('div');
        feedback.textContent = captureMode ? '🎥 Capture Mode ON' : '▶️ Playback Mode';
        feedback.style.cssText = `
          position: fixed;
          top: 50%;
          left: 50%;
          transform: translate(-50%, -50%);
          background: ${captureMode ? 'rgba(255, 255, 0, 0.9)' : 'rgba(0, 255, 0, 0.9)'};
          color: black;
          padding: 20px 40px;
          font-size: 18px;
          font-weight: bold;
          border-radius: 10px;
          z-index: 10001;
          // animation: fadeOut 1s forwards;
        `;
        document.body.appendChild(feedback);
        setTimeout(() => feedback.remove(), 1000);
        
        // Update debug overlay if visible
        if (debugOverlay.style.display === 'block') {
          updateDebugOverlay();
        }
      }
      
      function adjustCaptureTransform(type, delta) {
        if (!captureMode) {
          return;
        }
        
        if (type === 'scale') {
          currentScale = Math.min(Math.max(currentScale + delta, 0.1), 6);
          targetScale = currentScale;
        } else if (type === 'x') {
          currentTranslateX = Math.min(Math.max(currentTranslateX + delta, -120), 120);
          targetTranslateX = currentTranslateX;
        }
        
        applyContainerTransform();
        if (debugOverlay.style.display === 'block') {
          updateDebugOverlay();
        }
      }
      
      // Clear captured positions
      function clearCapturedPositions() {
        capturedPositions = [];
        console.log('🗑️ All captured positions cleared');
        
        // Show visual feedback
        const feedback = document.createElement('div');
        feedback.textContent = '🗑️ Positions Cleared';
        feedback.style.cssText = `
          position: fixed;
          top: 50%;
          left: 50%;
          transform: translate(-50%, -50%);
          background: rgba(255, 0, 0, 0.9);
          color: white;
          padding: 20px 40px;
          font-size: 18px;
          font-weight: bold;
          border-radius: 10px;
          z-index: 10001;
          // animation: fadeOut 1s forwards;
        `;
        document.body.appendChild(feedback);
        setTimeout(() => feedback.remove(), 1000);
      }
      
      // Keyboard shortcuts
      document.addEventListener('keydown', (e) => {
        // Ignore if user is typing in an input field
        if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') {
          return;
        }
        
        // Press 'M' to toggle capture mode
        if (e.key.toLowerCase() === 'm' && !e.ctrlKey && !e.metaKey) {
          e.preventDefault();
          toggleCaptureMode();
        }
        
        // Press 'C' to capture position
        if (e.key.toLowerCase() === 'c' && !e.ctrlKey && !e.metaKey) {
          e.preventDefault();
          capturePosition();
        }
        
        // Capture mode transform nudges
        if (captureMode && !e.ctrlKey && !e.metaKey) {
          const scaleStep = e.shiftKey ? 0.02 : 0.08;
          const xStep = e.shiftKey ? 0.4 : 1.5;
          const key = e.key.toLowerCase();
          
          // Scale controls
          if (
            e.key === '[' ||
            key === '-' ||
            key === '_' ||
            key === 'arrowdown' ||
            key === 's'
          ) {
            e.preventDefault();
            adjustCaptureTransform('scale', -scaleStep);
          }
          if (
            e.key === ']' ||
            key === '+' ||
            key === '=' ||
            key === 'arrowup' ||
            key === 'w'
          ) {
            e.preventDefault();
            adjustCaptureTransform('scale', scaleStep);
          }
          
          // X position controls
          if (e.key === ',' || key === 'arrowleft' || key === 'a') {
            e.preventDefault();
            adjustCaptureTransform('x', -xStep);
          }
          if (e.key === '.' || key === 'arrowright' || key === 'd') {
            e.preventDefault();
            adjustCaptureTransform('x', xStep);
          }
        }
        
        // Press 'D' to toggle debug overlay
        if (e.key.toLowerCase() === 'd' && !e.ctrlKey && !e.metaKey) {
          e.preventDefault();
          debugOverlay.style.display = debugOverlay.style.display === 'none' ? 'block' : 'none';
          if (debugOverlay.style.display === 'block') {
            updateDebugOverlay();
          }
        }
        
        // Press 'P' to print captured positions
        if (e.key.toLowerCase() === 'p' && !e.ctrlKey && !e.metaKey) {
          e.preventDefault();
          printCapturedPositions();
        }
        
        // Press 'X' to clear captured positions
        if (e.key.toLowerCase() === 'x' && !e.ctrlKey && !e.metaKey) {
          e.preventDefault();
          clearCapturedPositions();
        }
        
        // Press 'L' to toggle scroll animation logging
        if (e.key.toLowerCase() === 'l' && !e.ctrlKey && !e.metaKey) {
          e.preventDefault();
          window.debugScrollAnimation = !window.debugScrollAnimation;
          console.log(`🔍 Scroll Animation Logging: ${window.debugScrollAnimation ? 'ON' : 'OFF'}`);
        }
        
        // Press 'I' to toggle visual indicators
        if (e.key.toLowerCase() === 'i' && !e.ctrlKey && !e.metaKey) {
          e.preventDefault();
          if (centerIndicator) {
            centerIndicator.style.display = centerIndicator.style.display === 'none' ? 'block' : 'none';
          }
          if (progressIndicator) {
            progressIndicator.style.display = progressIndicator.style.display === 'none' ? 'block' : 'none';
          }
          console.log(`👁️ Visual Indicators: ${centerIndicator.style.display === 'block' ? 'ON' : 'OFF'}`);
        }
      });
      
      // Optimized scroll handler with throttling
      function handleScroll() {
        const scrollSection = document.getElementById('model-scroll-section');
        if (!scrollSection) {
          console.warn('model-scroll-section not found');
          return;
        }
        
        const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
        const viewportHeight = window.innerHeight;
        
        // Get section's absolute position in the document
        const sectionRect = scrollSection.getBoundingClientRect();
        const sectionTopAbsolute = scrollTop + sectionRect.top;
        const sectionHeight = scrollSection.offsetHeight;
        
        // Calculate scroll progress within the 400vh section
        // Model animation happens in first 200vh (0 to 0.5 of section)
        // About overlay appears in second 200vh (0.5 to 1.0 of section)
        const scrollWithinSection = scrollTop - sectionTopAbsolute;
        const totalScrollDistance = sectionHeight - viewportHeight;
        
        const sectionProgress = Math.min(Math.max(scrollWithinSection / totalScrollDistance, 0), 1);
        
        // Drive animation directly from section progress for true scroll-based transition.
        const animationProgress = sectionProgress;
        targetSectionProgress = animationProgress;
        
        // Reverse playback so scroll-down goes from end keyframes to start keyframes.
        const newScrollProgress = 1 - animationProgress;
        
        // Show model only while this section is in viewport.
        const sectionBottom = sectionTopAbsolute + sectionHeight;
        const isInView = scrollTop >= sectionTopAbsolute && scrollTop <= sectionBottom;

        if (modelContainer) {
          modelContainer.classList.toggle('is-active', isInView);
        }
        if (!isInView && keyframeTextBlock) {
          keyframeTextBlock.classList.remove('is-visible');
        }
        
        // Debug logging
        if (window.debugScrollAnimation) {
          console.log('Scroll Debug:', {
            scrollTop,
            sectionTopAbsolute,
            scrollWithinSection,
            totalScrollDistance,
            sectionProgress: (sectionProgress * 100).toFixed(2) + '%',
            modelAnimProgress: (newScrollProgress * 100).toFixed(2) + '%',
            isInView
          });
        }
        
        // Keep target in lockstep with scroll; RAF interpolation smooths final motion.
        targetScrollProgress = newScrollProgress;
        
        // Update camera and scale on every scroll for seamless animation
        if (!captureMode && isInView) {
          if (!animationFrameId) {
            animationFrameId = requestAnimationFrame(updateCameraAndScale);
          }
          
          // Debug: show animation state
          if (window.debugScrollAnimation) {
            const animState = sectionProgress < 0.5 ? 'ANIMATING 🎬' : 'HOLDING 🎯';
            console.log(`Model: ${animState} | Progress: ${(newScrollProgress * 100).toFixed(1)}%`);
          }
        }
        
        // Update debug overlay if visible
        if (debugOverlay.style.display === 'block') {
          updateDebugOverlay();
        }
        
        // Update progress indicator
        if (progressIndicator && progressIndicator.style.display === 'block') {
          const progressPercent = (newScrollProgress * 100).toFixed(1);
          const currentAngle = Math.round(newScrollProgress * 360);
          progressIndicator.innerHTML = `
            Progress: ${progressPercent}%<br>
            Rotation: ${currentAngle}°
          `;
        }
      }
      
      // Single optimized scroll listener
      window.addEventListener('scroll', handleScroll, { passive: true });
      
      // Update on resize
      window.addEventListener('resize', handleScroll, { passive: true });
      
      // Set exact initial hold pose + transform
      applyInitialHoldPose();
      
      // Initial setup
      handleScroll();
      
      // Log controls info
      console.log('🎮 Model Viewer Controls:');
      console.log('═══════════════════════════════════════');
      console.log('Press "M" - Toggle Capture/Playback Mode');
      console.log('Press "C" - Capture current scroll/camera position');
      console.log('Press "D" - Toggle debug overlay');
      console.log('Press "I" - Toggle visual indicators (center + progress)');
      console.log('Press "P" - Print all captured positions');
      console.log('Press "X" - Clear all captured positions');
      console.log('Press "L" - Toggle scroll animation logging');
      console.log('Scale in Capture Mode: Arrow Up/Down, +/- or [/]');
      console.log('Move X in Capture Mode: Arrow Left/Right, A/D or ,/.');
      console.log('═══════════════════════════════════════');
      console.log('\n💡 WORKFLOW:');
      console.log('1. Press "M" to enable Capture Mode');
      console.log('2. Manually position the camera (drag, zoom)');
      console.log('3. Scroll to different positions');
      console.log('4. Press "C" at each position to capture');
      console.log('5. Press "P" to export captured positions');
      console.log('6. Press "M" to return to Playback Mode');
      console.log('═══════════════════════════════════════\n');
      
      // Initialize debug flag
      window.debugScrollAnimation = false;
    });
  }
  
  // Start initialization
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initModelViewer);
  } else {
    initModelViewer();
  }
  
  // Handle About overlay visibility
  function handleAboutVisibility() {
    const modelSection = document.getElementById('model-scroll-section');
    const aboutContent = document.getElementById('about-content');
    
    if (!modelSection || !aboutContent) {
      console.error('❌ About overlay elements not found!', { modelSection, aboutContent });
      return;
    }
    
    console.log('✅ About overlay initialized', { 
      modelSection: modelSection.id, 
      aboutContent: aboutContent.id,
      sectionHeight: modelSection.offsetHeight,
      sectionTop: modelSection.offsetTop
    });
    
    let targetSectionProgress = 0;
    let smoothedSectionProgress = 0;
    let isSectionInView = false;
    let smoothRafId = null;
    const smoothingFactor = 0.075; // lower = heavier/slower inertia

    function renderFloatingImages(progress: number) {
      // Update text highlight
      const textHighlight = document.querySelector('.about-text-highlight');
      if (textHighlight) {
        const highlightPercent = progress * 100;
        textHighlight.style.setProperty('--highlight-progress', `${highlightPercent}%`);
      }

      // Animate floating images from right edge to fixed X/Y viewport coordinates.
      const floatingImages = document.querySelectorAll('.floating-image');
      const floatingTargets = [
        { x: 10, y: 18 },
        { x: 28, y: 62 },
        { x: 45, y: 28 },
        { x: 62, y: 58 },
        { x: 74, y: 22 },
        { x: 82, y: 68 }
      ];

      floatingImages.forEach((image, index) => {
        if (!image.dataset.seeded) {
          const target = floatingTargets[index] || floatingTargets[floatingTargets.length - 1];
          image.dataset.seeded = '1';
          image.dataset.baseX = target.x.toFixed(2);
          image.dataset.baseY = target.y.toFixed(2);
          image.dataset.entryShift = '14';                                        // same start offset for uniform speed
          image.dataset.scale = '1';                                              // keep final layout consistent
        }

        const baseX = Number(image.dataset.baseX || 50);
        const entryShift = Number(image.dataset.entryShift || 12);
        const baseY = Number(image.dataset.baseY || 50);
        const scale = Number(image.dataset.scale || 1);

        // Keep final layout spacing intact and slide the whole layout from right to left.
        const layoutOffsetX = (1 - progress) * (100 + entryShift);
        const translateX = baseX + layoutOffsetX;
        const translateY = baseY;

        // Start reveal only after image enters viewport from the right.
        const hasEnteredViewport = translateX <= 78;
        const revealTravel = Math.max(16, Math.min(36, 100 - baseX));
        const revealProgress = hasEnteredViewport
          ? Math.min(Math.max((100 - translateX) / revealTravel, 0), 1)
          : 0;
        const clipInset = (1 - revealProgress) * 50;

        image.style.setProperty('--clip-top', `${clipInset}%`);
        image.style.setProperty('--clip-bottom', `${clipInset}%`);
        image.style.setProperty('--scale', scale.toFixed(3));
        image.style.setProperty('--translate-x', `${translateX}vw`);
        image.style.setProperty('--translate-y', `${translateY}vh`);
        image.style.setProperty('--opacity', '1');
      });
    }

    function resetFloatingImages() {
      const floatingImages = document.querySelectorAll('.floating-image');
      floatingImages.forEach((image) => {
        const entryShift = Number(image.dataset.entryShift || 12);
        const hiddenX = 100 + entryShift + 4;
        const baseY = Number(image.dataset.baseY || 100);
        image.style.setProperty('--translate-x', `${hiddenX}vw`);
        image.style.setProperty('--translate-y', `${baseY}vh`);
        image.style.setProperty('--scale', '0.3');
        image.style.setProperty('--opacity', '0');
        image.style.setProperty('--clip-top', '50%');
        image.style.setProperty('--clip-bottom', '50%');
      });
    }

    function runSmoothFrame() {
      const delta = targetSectionProgress - smoothedSectionProgress;
      smoothedSectionProgress += delta * smoothingFactor;

      if (isSectionInView) {
        aboutContent.style.zIndex = '50';
        aboutContent.style.opacity = '1';
        renderFloatingImages(smoothedSectionProgress);
      } else {
        aboutContent.style.zIndex = '-1';
        aboutContent.style.opacity = '0';
        resetFloatingImages();
      }

      if (Math.abs(delta) > 0.0008 || isSectionInView) {
        smoothRafId = requestAnimationFrame(runSmoothFrame);
      } else {
        smoothedSectionProgress = targetSectionProgress;
        smoothRafId = null;
      }
    }

    function ensureSmoothLoop() {
      if (smoothRafId === null) {
        smoothRafId = requestAnimationFrame(runSmoothFrame);
      }
    }

    function updateVisibility() {
      const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
      const viewportHeight = window.innerHeight;
      
      // Get the absolute position of the section from the document top
      const sectionTopAbsolute = modelSection.offsetTop;
      const sectionHeight = modelSection.offsetHeight; // 400vh
      
      const sectionBottom = sectionTopAbsolute + sectionHeight;
      const totalScrollable = Math.max(sectionHeight - viewportHeight, 1);
      const sectionProgress = Math.min(Math.max((scrollTop - sectionTopAbsolute) / totalScrollable, 0), 1);
      
      // Show floating items for the full model section.
      isSectionInView = scrollTop >= sectionTopAbsolute && scrollTop < sectionBottom;
      targetSectionProgress = sectionProgress;
      ensureSmoothLoop();
    }
    
    window.addEventListener('scroll', updateVisibility, { passive: true });
    window.addEventListener('resize', updateVisibility, { passive: true });
    
    // Initial check
    updateVisibility();
    
    // Check again after a short delay to ensure everything is loaded
    setTimeout(updateVisibility, 100);
  }
  
  // Initialize about overlay
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', handleAboutVisibility);
  } else {
    handleAboutVisibility();
  }
</script>

