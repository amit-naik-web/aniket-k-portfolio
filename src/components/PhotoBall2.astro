---
const canvasSize = 220;
---

<div class="photo-ball-hover" data-photo-ball-hover>
  <canvas class="photo-ball-canvas" width={canvasSize} height={canvasSize}></canvas>
</div>

<script>
  (() => {
    const wrappers = document.querySelectorAll('[data-photo-ball-hover]:not([data-photo-ball-ready])');
    if (!wrappers.length) return;

    const IDLE_SPEED = 0.003;
    const HOVER_SPEED = 0.018;
    const SPEED_LERP = 0.06;
    const VISUAL_LERP = 0.1;
    const FOLLOW_LERP = 0.18;
    const EXIT_TRAIL_MS = 260;
    const EXIT_TRAIL_DISTANCE = 120;
    const axis = { x: -1 / Math.SQRT2, y: 1 / Math.SQRT2, z: 0 };
    const imgIds = [
      '1506905925346-21bda4d32df4','1470071459604-3b5ec3a7fe05','1501854140801-50d01698950b',
      '1441974231531-c6227db76b6e','1518020382113-a7e8fc38eac9','1507003211169-0a1dd7228f2d',
      '1494790108377-be9c29b29330','1472214103451-9374bd1c798e','1519681393784-d120267933ba',
      '1502082553048-f009c37129b9','1464822759023-fed622ff2c3b','1426604966848-d7adac402bff',
      '1500534314209-a25ddb2bd429','1532274402911-5a369e4c4bb5','1534430480872-3498386e7856',
      '1540979388789-6cee28a1cdc9','1547471080-7cc2caa01a7e','1551632811-561732d1e306',
      '1559827291-72416316a7b0','1566438480900-0609be27db4c','1574169208507-84376144848b',
      '1578632767115-351597cf2a0d','1580489944761-15a19d654956','1583394838336-acd977736f90',
      '1586348943529-beaae6c28db9','1589394815804-964ed0be2eb5','1590523741831-ab7e8b8f9c7f',
      '1598300042247-d088f8ab3a91','1601758125940-8f527e22a4ac','1604537466158-719b1972feb8',
      '1609921212029-bb5a28e60960','1614851099175-e5322f1f639b','1617957718587-13e31b39da5b',
      '1622547748225-3fc4abd2cca0','1625244695730-7ace6c8e8c1b','1628191081676-24f57f57d5e6',
      '1472396961693-142e6e269027','1433086074074-e4f486ddfe1f','1418065460487-3e41a6c84dc5',
      '1439853949212-36652a89b5f6','1445294211564-3ca59d999abd','1448375240586-882707db888b',
      '1453728013993-6d66e9c9123a','1456428746267-a1756408f782','1463003785364-5d9e3bec6807',
      '1469474968028-56623f02e42e','1471922694854-ff1b63b20054','1475924156734-496f6cac6ec1',
      '1477322524774-a39f8ec0a0c4','1480714378702-484de788b4cc','1482686115713-0fbcaced6e28',
      '1484318571209-661cf29a69d8','1488330219917-7b6eda23ef66','1490750967868-88df5691b2e3'
    ];
    const baseW = [0.34, 0.25, 0.30, 0.36, 0.23, 0.32, 0.27, 0.36, 0.30, 0.25];
    const baseH = [0.25, 0.32, 0.30, 0.23, 0.30, 0.25, 0.34, 0.23, 0.28, 0.32];

    function fibSphere(n) {
      const pts = [];
      const golden = Math.PI * (3 - Math.sqrt(5));
      for (let i = 0; i < n; i++) {
        const y = 1 - (i / (n - 1)) * 2;
        const r = Math.sqrt(1 - y * y);
        const t = golden * i;
        pts.push([r * Math.cos(t), y, r * Math.sin(t)]);
      }
      return pts;
    }

    function qMul(a, b) {
      return {
        w: a.w * b.w - a.x * b.x - a.y * b.y - a.z * b.z,
        x: a.w * b.x + a.x * b.w + a.y * b.z - a.z * b.y,
        y: a.w * b.y - a.x * b.z + a.y * b.w + a.z * b.x,
        z: a.w * b.z + a.x * b.y - a.y * b.x + a.z * b.w
      };
    }

    function qNorm(q) {
      const l = Math.sqrt(q.w * q.w + q.x * q.x + q.y * q.y + q.z * q.z) || 1;
      return { w: q.w / l, x: q.x / l, y: q.y / l, z: q.z / l };
    }

    function qFromAxisAngle(ax, angle) {
      const s = Math.sin(angle / 2);
      return { w: Math.cos(angle / 2), x: ax.x * s, y: ax.y * s, z: ax.z * s };
    }

    function applyQ(q, v) {
      const qv = { w: 0, x: v[0], y: v[1], z: v[2] };
      const qc = { w: q.w, x: -q.x, y: -q.y, z: -q.z };
      const r = qMul(qMul(q, qv), qc);
      return [r.x, r.y, r.z];
    }

    const unitPts = fibSphere(imgIds.length);
    const imgs = imgIds.map((id, i) => {
      const im = new Image();
      im.crossOrigin = 'anonymous';
      im.src = `https://images.unsplash.com/photo-${id}?w=200&h=200&fit=crop&auto=format`;
      return { el: im, bw: baseW[i % baseW.length], bh: baseH[i % baseH.length] };
    });

    const fallbacks = ['#e8a87c', '#85c1e9', '#82e0aa', '#f1948a', '#c39bd3', '#f8c471'];

    wrappers.forEach((wrapper) => {
      wrapper.setAttribute('data-photo-ball-ready', 'true');
      const canvas = wrapper.querySelector('canvas');
      const card = wrapper.closest('[data-collection-card]');
      if (!canvas || !card) return;

      const ctx = canvas.getContext('2d');
      if (!ctx) return;

      const W = canvas.width;
      const H = canvas.height;
      const CX = W / 2;
      const CY = H / 2;
      const FOCAL = (W / 2) / Math.tan((45 * Math.PI / 180) / 2);
      const CAM_Z = 5.2;
      const SPHERE_R = 1.58;
      const FADE_END = -0.15 * SPHERE_R;
      const FADE_START = 0.15 * SPHERE_R;

      let qRot = { w: 1, x: 0, y: 0, z: 0 };
      let currentSpeed = IDLE_SPEED;
      let targetSpeed = IDLE_SPEED;
      let currentScale = 0;
      let targetScale = 0;
      let currentOpacity = 0;
      let targetOpacity = 0;
      let currentX = 0;
      let currentY = 0;
      let targetX = 0;
      let targetY = 0;
      let exitTrailActive = false;
      let exitTrailStartedAt = 0;
      let leaveClientX = 0;
      let leaveClientY = 0;
      let leaveLocalX = 0;
      let leaveLocalY = 0;

      const defaultPos = () => {
        const rect = card.getBoundingClientRect();
        targetX = rect.width * 0.76;
        targetY = rect.height * 0.68;
      };
      defaultPos();
      currentX = targetX;
      currentY = targetY;

      const showBall = () => {
        targetSpeed = HOVER_SPEED;
        targetScale = 1;
        targetOpacity = 1;
      };

      const setTargetFromPointer = (event) => {
        const rect = card.getBoundingClientRect();
        targetX = event.clientX - rect.left;
        targetY = event.clientY - rect.top;
      };

      const hideBall = () => {
        targetSpeed = IDLE_SPEED;
        targetScale = 0;
        targetOpacity = 0;
      };

      const stopExitTrail = () => {
        exitTrailActive = false;
        window.removeEventListener('mousemove', followExitCursor);
      };

      const followExitCursor = (event) => {
        if (!exitTrailActive) return;
        const elapsed = performance.now() - exitTrailStartedAt;
        if (elapsed >= EXIT_TRAIL_MS) {
          stopExitTrail();
          return;
        }

        const dx = event.clientX - leaveClientX;
        const dy = event.clientY - leaveClientY;
        const dist = Math.hypot(dx, dy);
        const cap = dist > EXIT_TRAIL_DISTANCE ? EXIT_TRAIL_DISTANCE / dist : 1;
        targetX = leaveLocalX + dx * cap;
        targetY = leaveLocalY + dy * cap;
      };

      card.addEventListener('mouseenter', (event) => {
        stopExitTrail();
        setTargetFromPointer(event);
        currentX = targetX;
        currentY = targetY;
        showBall();
      });
      card.addEventListener('mouseleave', (event) => {
        setTargetFromPointer(event);
        currentX = targetX;
        currentY = targetY;
        leaveClientX = event.clientX;
        leaveClientY = event.clientY;
        leaveLocalX = targetX;
        leaveLocalY = targetY;
        exitTrailActive = true;
        exitTrailStartedAt = performance.now();
        window.addEventListener('mousemove', followExitCursor);
        hideBall();
      });
      card.addEventListener('focusin', showBall);
      card.addEventListener('focusout', hideBall);
      card.addEventListener('mousemove', setTargetFromPointer);
      window.addEventListener('resize', () => {
        if (targetOpacity < 0.01) defaultPos();
      });

      function frame() {
        requestAnimationFrame(frame);

        currentSpeed += (targetSpeed - currentSpeed) * SPEED_LERP;
        currentScale += (targetScale - currentScale) * VISUAL_LERP;
        currentOpacity += (targetOpacity - currentOpacity) * VISUAL_LERP;
        currentX += (targetX - currentX) * FOLLOW_LERP;
        currentY += (targetY - currentY) * FOLLOW_LERP;

        if (exitTrailActive && currentOpacity < 0.02 && currentScale < 0.02) {
          stopExitTrail();
        }

        qRot = qNorm(qMul(qFromAxisAngle(axis, currentSpeed), qRot));

        wrapper.style.opacity = currentOpacity.toFixed(4);
        // Keep cursor near bottom-left, but nudge sphere slightly down and closer.
        wrapper.style.transform =
          `translate3d(${(currentX - 8).toFixed(1)}px, ${(currentY - H + 14).toFixed(1)}px, 0) ` +
          `scale(${currentScale.toFixed(2)})`;

        ctx.clearRect(0, 0, W, H);
        if (currentOpacity < 0.004 && currentScale < 0.004) return;

        const items = unitPts.map((p, i) => {
          const rp = applyQ(qRot, p);
          const wz = rp[2] * SPHERE_R;
          const camZ = CAM_Z - wz;
          const s = FOCAL / camZ;
          const sx = CX + rp[0] * SPHERE_R * s;
          const sy = CY + rp[1] * SPHERE_R * s;
          const t = (wz / SPHERE_R + 1) / 2;
          const sizeScale = 0.12 + Math.pow(t, 2.2);
          const fadeT = Math.min(1, (wz - FADE_END) / (FADE_START - FADE_END));
          const opacity = fadeT * (0.2 + Math.pow(t, 1.8) * 0.8);
          const { bw, bh } = imgs[i];
          const pw = bw * SPHERE_R * s * sizeScale;
          const ph = bh * SPHERE_R * s * sizeScale;
          return { i, sx, sy, wz, opacity, pw, ph, s, sizeScale };
        });

        items.sort((a, b) => a.wz - b.wz);

        for (const { i, sx, sy, wz, opacity, pw, ph, s, sizeScale } of items) {
          if (wz < FADE_END || opacity < 0.01) continue;
          const { el } = imgs[i];
          const bpad = 0.01 * SPHERE_R * s * sizeScale;

          ctx.save();
          ctx.globalAlpha = opacity;
          ctx.fillStyle = '#ffffff';
          ctx.fillRect(sx - pw / 2 - bpad, sy - ph / 2 - bpad, pw + bpad * 2, ph + bpad * 2);

          if (el.complete && el.naturalWidth > 0) {
            ctx.drawImage(el, sx - pw / 2, sy - ph / 2, pw, ph);
          } else {
            ctx.fillStyle = fallbacks[i % fallbacks.length];
            ctx.fillRect(sx - pw / 2, sy - ph / 2, pw, ph);
          }
          ctx.restore();
        }
      }

      frame();
    });
  })();
</script>

<style>
  .photo-ball-hover {
    position: absolute;
    left: 0;
    top: 0;
    width: 220px;
    height: 220px;
    opacity: 0;
    transform: scale(0);
    transform-origin: 0% 100%;
    pointer-events: none;
    z-index: 1;
    will-change: transform, opacity;
  }

  .photo-ball-canvas {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>
