---
const items = [
  { name: "EVENTS" },
  { name: "PHOTOSHOOTS" },
  { name: "INTERVIEWS" },
  { name: "ADVERTISMENTS" },
  { name: "SHORTFILMS" },
  { name: "MISC." },
];
---

<div
  id="preview-list-showcase"
  class="relative w-full bg-black"
  style={`height: ${items.length * 100}vh;`}
>
  <div
    id="preview-list-screen"
    class="pointer-events-none fixed inset-0 z-10 flex items-center justify-center opacity-0"
    aria-hidden="true"
  >
    <div class="preview-screen-shell">
      <div class="preview-screen-sideglow preview-screen-sideglow-left"></div>
      <div class="preview-screen-sideglow preview-screen-sideglow-right"></div>
      <div class="preview-screen-glow"></div>
      <svg
        class="preview-screen-svg"
        viewBox="0 0 1200 560"
        preserveAspectRatio="none"
        aria-hidden="true"
      >
        <defs>
          <linearGradient id="preview-screen-fill" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="rgba(255,255,255,1)" />
            <stop offset="62%" stop-color="rgba(251,251,251,1)" />
            <stop offset="100%" stop-color="rgba(238,238,238,1)" />
          </linearGradient>
          <linearGradient id="preview-screen-stroke" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="rgba(255,255,255,0.78)" />
            <stop offset="100%" stop-color="rgba(255,255,255,0.18)" />
          </linearGradient>
        </defs>
        <path
          class="preview-screen-surface-path"
          d="M32 96 C220 46 980 46 1168 96 L1168 464 C980 414 220 414 32 464 Z"
          fill="url(#preview-screen-fill)"
        />
        <path
          class="preview-screen-frame-path"
          d="M32 96 C220 46 980 46 1168 96 L1168 464 C980 414 220 414 32 464 Z"
          fill="none"
          stroke="url(#preview-screen-stroke)"
          stroke-width="3"
          vector-effect="non-scaling-stroke"
        />
      </svg>
    </div>
  </div>

  <div class="relative z-20 flex justify-center">
    <div class="mx-auto flex w-full max-w-[580px] flex-col items-center px-4">
      {
        items.map((item) => (
          <div class="relative flex h-screen w-full items-center justify-center">
            <h2
              data-scale-item
              class="relative z-10 flex h-full items-center justify-center text-center font-black text-6xl leading-none tracking-tight text-black/85 md:text-7xl"
            >
              {item.name}
            </h2>
          </div>
        ))
      }
    </div>
  </div>
</div>

<script>
  const showcaseSection = document.getElementById("preview-list-showcase");
  const screenBackdrop = document.getElementById("preview-list-screen");
  const scaleItems = Array.from(
    document.querySelectorAll<HTMLElement>("[data-scale-item]"),
  );

  const ANIMATION_START_VH = 0.20;
  const ANIMATION_PEAK_VH = 0.80;
  const ANIMATION_END_VH = 0.95;
  const MAX_SCALE_X = 1.5;
  const SMOOTHING = 0.11;
  const SETTLE_THRESHOLD = 0.002;

  const clamp = (value: number, min: number, max: number) =>
    Math.min(Math.max(value, min), max);

  const lerp = (start: number, end: number, progress: number) =>
    start + (end - start) * progress;

  const easeInOutCubic = (value: number) =>
    value < 0.5 ? 4 * value * value * value : 1 - Math.pow(-2 * value + 2, 3) / 2;
  const easeOutQuint = (value: number) => 1 - Math.pow(1 - value, 5);

  const itemState = new WeakMap<
    HTMLElement,
    {
      currentX: number;
      targetX: number;
    }
  >();

  scaleItems.forEach((item) => {
    itemState.set(item, {
      currentX: 1,
      targetX: 1,
    });
  });

  function getScaleIntensity(position: number) {
    if (position <= ANIMATION_START_VH || position >= ANIMATION_END_VH) return 0;

    if (position < ANIMATION_PEAK_VH) {
      const progress = clamp(
        (position - ANIMATION_START_VH) / (ANIMATION_PEAK_VH - ANIMATION_START_VH),
        0,
        1,
      );
      return easeInOutCubic(progress);
    }

    if (position === ANIMATION_PEAK_VH) return 1;

    const progress = clamp(
      (position - ANIMATION_PEAK_VH) / (ANIMATION_END_VH - ANIMATION_PEAK_VH),
      0,
      1,
    );
    return 1 - easeOutQuint(progress);
  }

  let measureRafId: number | null = null;
  let animateRafId: number | null = null;

  function animateItemScale() {
    animateRafId = null;
    let shouldContinue = false;

    scaleItems.forEach((item) => {
      const state = itemState.get(item);
      if (!state) return;

      state.currentX = lerp(state.currentX, state.targetX, SMOOTHING);

      const deltaX = Math.abs(state.targetX - state.currentX);
      if (deltaX > SETTLE_THRESHOLD) {
        shouldContinue = true;
      }

      item.style.setProperty("--item-scale-x", state.currentX.toFixed(3));
    });

    if (shouldContinue) {
      animateRafId = requestAnimationFrame(animateItemScale);
    }
  }

  function ensureAnimation() {
    if (animateRafId !== null) return;
    animateRafId = requestAnimationFrame(animateItemScale);
  }

  function updateItemScaleTargets() {
    measureRafId = null;
    const viewportHeight = window.innerHeight;
    const sectionRect = showcaseSection?.getBoundingClientRect();
    const isSectionActive = Boolean(
      sectionRect &&
        sectionRect.top < viewportHeight &&
        sectionRect.bottom > 0,
    );

    screenBackdrop?.classList.toggle("is-visible", isSectionActive);

    scaleItems.forEach((item) => {
      const state = itemState.get(item);
      if (!state) return;

      const rect = item.getBoundingClientRect();
      const itemCenter = rect.top + rect.height / 2;
      const viewportPosition = itemCenter / viewportHeight;
      const intensity = getScaleIntensity(viewportPosition);
      state.targetX = lerp(1, MAX_SCALE_X, intensity);
    });

    ensureAnimation();
  }

  function requestScaleUpdate() {
    if (measureRafId !== null) return;
    measureRafId = requestAnimationFrame(updateItemScaleTargets);
  }

  updateItemScaleTargets();

  window.addEventListener("scroll", requestScaleUpdate, { passive: true });
  window.addEventListener("resize", requestScaleUpdate, { passive: true });
  window.addEventListener("beforeunload", () => {
    if (measureRafId !== null) cancelAnimationFrame(measureRafId);
    if (animateRafId !== null) cancelAnimationFrame(animateRafId);
  });
</script>

<style>
  #preview-list-screen {
    visibility: hidden;
    transition: opacity 220ms ease;
  }

  #preview-list-screen.is-visible {
    visibility: visible;
    opacity: 1;
  }

  .preview-screen-shell {
    position: relative;
    width: min(94vw, 72rem);
    height: min(48vh, 30rem);
    display: flex;
    align-items: center;
    justify-content: center;
    transform: perspective(1800px) rotateX(-11deg);
    overflow: visible;
  }

  .preview-screen-sideglow {
    position: absolute;
    top: 3%;
    bottom: 3%;
    width: clamp(1.1rem, 2vw, 1.75rem);
    background: linear-gradient(
      180deg,
      rgba(114, 177, 255, 0.35) 0%,
      rgba(60, 130, 255, 0.55) 50%,
      rgba(114, 177, 255, 0.25) 100%
    );
    filter: blur(18px);
    opacity: 0.75;
  }

  .preview-screen-sideglow-left {
    left: 0.4%;
  }

  .preview-screen-sideglow-right {
    right: 0.4%;
  }

  .preview-screen-glow {
    position: absolute;
    inset: 4% 2.2% -12%;
    background: radial-gradient(
      ellipse at center,
      rgba(255, 255, 255, 0.28) 0%,
      rgba(255, 255, 255, 0.12) 48%,
      rgba(255, 255, 255, 0) 78%
    );
    filter: blur(32px);
    transform: scaleY(0.74);
  }

  .preview-screen-svg {
    display: block;
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  .preview-screen-surface-path {
    filter: drop-shadow(0 18px 60px rgba(255, 255, 255, 0.07));
  }

  .preview-screen-frame-path {
    filter: drop-shadow(0 24px 70px rgba(255, 255, 255, 0.08));
  }

  [data-scale-item] {
    transform: scaleX(var(--item-scale-x, 1));
    transform-origin: center;
    will-change: transform;
    backface-visibility: hidden;
  }
</style>
