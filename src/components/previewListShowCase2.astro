---
const items = [
  { name: "PHOTOS",       preview: "/anjunadeep.jpg",      type: "image" },
  { name: "INTERVIEWS",   preview: "/martin-garrix.mp4",   type: "video" },
  { name: "SHOWS",        preview: "/coldplay.jpg",         type: "image" },
  { name: "ADVERTISMENTS",preview: "bryan-adams.png",      type: "image" },
  { name: "SHORTFILMS",   preview: "/klang-preview-3.jpg", type: "image" },
  { name: "MISC.",        preview: "korolova.mp4",          type: "video" },
];
---

<!-- SVG filter lives outside the sticky layer so it's always in the DOM -->
<svg class="absolute w-0 h-0 pointer-events-none" aria-hidden="true" focusable="false"
     style="position:fixed;top:0;left:0;">
  <defs>
    <filter id="liquid-refraction-filter" x="-20%" y="-20%" width="140%" height="140%">
      <feTurbulence
        id="liquid-turbulence"
        type="fractalNoise"
        baseFrequency="0.009 0.022"
        numOctaves="2"
        seed="3"
        result="turbulence"
      />
      <feDisplacementMap in="SourceGraphic" in2="turbulence" scale="32" />
    </filter>
  </defs>
</svg>

<!-- Outer scroll-travel wrapper — gives the browser scroll distance to work with -->
<div
  id="showcase-outer"
  class="relative w-full"
  style="height: 300vh;"
>
  <!-- Sticky viewport — stays pinned while outer scrolls -->
  <div
    id="showcase-sticky"
    class="sticky top-0 w-full overflow-hidden"
    style="height: 100vh;"
  >
    <!-- Fixed background -->
    <div id="preview-bg" class="absolute inset-0 will-change-contents">
      {items.filter(i => i.type === "video").map((item) => (
        <video
          data-video-src={item.preview}
          class="hidden w-full h-full object-cover"
          muted loop preload="metadata"
        >
          <source src={item.preview} type="video/mp4" />
        </video>
      ))}
      <!-- <div
        id="bg-image"
        class="absolute inset-0 bg-cover bg-center transition-opacity duration-500 ease-in-out"
        style={`background-image: url(${items[0].preview})`}
      ></div>
      <div id="bg-video-container" class="absolute inset-0 opacity-0 transition-opacity duration-500 ease-in-out"></div> -->
    </div>

    <!-- Dark overlay -->
    <div class="absolute inset-0 bg-black/60 pointer-events-none"></div>

    <!-- Liquid glass pill — fixed at screen center, always visible -->
    <div
      id="glass-frame"
      class="pointer-events-none fixed z-30 rounded-[42px]"
      style="
        left: 50%;
        top: 50%;
        transform: translate(-50%, -50%);
        width: min(90vw, 580px);
        height: 72px;
      "
    ></div>

    <!-- List track — translated by JS as user scrolls -->
    <div
      id="list-scroll-track"
      class="absolute z-20"
      style="
        left: 50%;
        transform: translateX(-50%);
        width: min(90vw, 580px);
        will-change: transform;
      "
      set:html={items.map((item, idx) => `
        <div
          class="cascade-item w-full border-t border-white/30 flex flex-row justify-between items-center
                 px-4 rounded-[42px] opacity-0 translate-y-6
                 transition-[opacity,transform] duration-500 ease-out"
          data-index="${idx}"
          data-preview="${item.preview}"
          data-type="${item.type}"
          style="height:72px; transition-delay:${idx * 80}ms;"
        >
          <h2 class="cascade-title flex items-center gap-3 w-full font-black text-3xl md:text-4xl
                     text-white/60 transition-colors duration-300"
              style="height:100%;">
            <span class="text-sm font-normal opacity-60">(${String(idx + 1).padStart(3, "0")})</span>
            <span>${item.name}</span>
          </h2>
          <div class="relative shrink-0 w-8 h-8 flex items-center justify-center">
            <img src="/assets/up-right-arrow-gray.png"  alt="${item.name}" width="32" height="32"
                 class="arrow-default  w-8 h-8 object-cover transition-opacity duration-300"
                 style="filter:contrast(1.8) brightness(0.6);" loading="lazy" />
            <img src="/assets/up-right-arrow-black.png" alt="${item.name}" width="32" height="32"
                 class="arrow-active absolute inset-0 w-8 h-8 object-cover opacity-0 transition-opacity duration-300"
                 style="filter:contrast(2) brightness(0.5);" loading="lazy" />
          </div>
        </div>
      `).join("")}
    />
  </div>
</div>

<script>
  const outerSection  = document.getElementById("showcase-outer")    as HTMLElement | null;
  const listTrack     = document.getElementById("list-scroll-track")  as HTMLElement | null;
  const glassFrame    = document.getElementById("glass-frame")        as HTMLElement | null;
  const bgImage       = document.getElementById("bg-image")           as HTMLElement | null;
  const bgVideoContainer = document.getElementById("bg-video-container") as HTMLElement | null;
  const turbulenceEl  = document.getElementById("liquid-turbulence");
  const preloadedVideos = new Map<string, HTMLVideoElement>();

  document.querySelectorAll("[data-video-src]").forEach((v) => {
    const src = v.getAttribute("data-video-src");
    if (src && v instanceof HTMLVideoElement) preloadedVideos.set(src, v);
  });

  const listItems = Array.from(document.querySelectorAll<HTMLElement>(".cascade-item"));
  const ITEM_H    = 72; // must match height in template
  const N         = listItems.length;

  // ── Position list track so first item starts at viewport center ──────────
  function positionTrack() {
    if (!listTrack) return;
    const baseTop = window.innerHeight / 2 - ITEM_H / 2;
    listTrack.style.top = `${baseTop}px`;
  }
  positionTrack();

  // ── Scroll-driven list translation ──────────────────────────────────────
  let scrollRafId: number | null = null;
  let currentVideo: HTMLVideoElement | null = null;
  let isTransitioning = false;
  let activeIndex = -1;

  function onScroll() {
    if (scrollRafId !== null) return;
    scrollRafId = requestAnimationFrame(tick);
  }

  function tick() {
    scrollRafId = null;
    if (!outerSection || !listTrack) return;

    const rect      = outerSection.getBoundingClientRect();
    const scrolled  = -rect.top;                                   // px scrolled past section top
    const maxScroll = outerSection.offsetHeight - window.innerHeight; // total travel budget
    const progress  = Math.max(0, Math.min(1, scrolled / maxScroll));
    const sectionActive = rect.top < window.innerHeight && rect.bottom > 0;

    if (glassFrame) {
      glassFrame.style.opacity = sectionActive ? "1" : "0";
    }

    const totalTravel = (N - 1) * ITEM_H;
    const ty          = -totalTravel * progress;
    listTrack.style.transform = `translate3d(-50%, ${ty}px, 0)`;

    // Which item index is at center?
    const nextActive = Math.round(progress * (N - 1));
    if (nextActive !== activeIndex) {
      activeIndex = nextActive;
      highlightItem(nextActive);
    }
  }

  function highlightItem(idx: number) {
    listItems.forEach((item, i) => {
      if (i === idx) {
        item.classList.add("is-centered");
      } else {
        item.classList.remove("is-centered");
      }
    });
    const item = listItems[idx];
    if (!item) return;
    const url  = item.getAttribute("data-preview");
    const type = item.getAttribute("data-type");
    if (url && type) debouncedSwitch(url, type);
  }

  // ── Preview switcher ─────────────────────────────────────────────────────
  function switchPreview(url: string, type: string) {
    if (isTransitioning || !bgImage || !bgVideoContainer) return;
    isTransitioning = true;
    if (type === "video") {
      let v = preloadedVideos.get(url);
      if (!v) {
        v = document.createElement("video");
        v.className = "w-full h-full object-cover";
        v.muted = v.loop = v.playsInline = true;
        const s = document.createElement("source");
        s.src  = url; s.type = "video/mp4";
        v.appendChild(s);
        preloadedVideos.set(url, v);
      }
      if (currentVideo && currentVideo !== v) { currentVideo.pause(); currentVideo.currentTime = 0; }
      bgVideoContainer.innerHTML = "";
      bgVideoContainer.appendChild(v.cloneNode(true) as HTMLVideoElement);
      const nv = bgVideoContainer.querySelector("video") as HTMLVideoElement | null;
      if (nv) { nv.play().catch(() => {}); currentVideo = nv; }
      bgImage.style.opacity = "0";
      bgVideoContainer.style.opacity = "1";
    } else {
      if (currentVideo) { currentVideo.pause(); currentVideo.currentTime = 0; }
      bgImage.style.backgroundImage = `url(${url})`;
      bgVideoContainer.style.opacity = "0";
      bgImage.style.opacity = "1";
    }
    setTimeout(() => { isTransitioning = false; }, 150);
  }

  function debounce(fn: (...a: any[]) => void, ms: number) {
    let t: ReturnType<typeof setTimeout> | undefined;
    return (...a: any[]) => { clearTimeout(t); t = setTimeout(() => fn(...a), ms); };
  }
  const debouncedSwitch = debounce(switchPreview, 60);

  // ── Cascade entrance observer ────────────────────────────────────────────
  const sectionObserver = new IntersectionObserver((entries, obs) => {
    entries.forEach((e) => {
      if (!e.isIntersecting) return;
      listItems.forEach((item) => {
        item.classList.remove("opacity-0", "translate-y-6");
        item.classList.add("opacity-100", "translate-y-0");
      });
      tick();
      obs.unobserve(e.target);
    });
  }, { threshold: 0.1 });

  if (outerSection) sectionObserver.observe(outerSection);

  window.addEventListener("scroll", onScroll, { passive: true });
  window.addEventListener("resize", () => { positionTrack(); tick(); }, { passive: true });

  // ── Animate liquid glass turbulence ─────────────────────────────────────
  let liquidRafId: number | null = null;
  function animateLiquid() {
    if (!turbulenceEl) return;
    const t  = performance.now() * 0.001;
    const fx = (0.009 + Math.sin(t * 0.7) * 0.0013).toFixed(4);
    const fy = (0.022 + Math.cos(t * 0.55) * 0.002).toFixed(4);
    turbulenceEl.setAttribute("baseFrequency", `${fx} ${fy}`);
    liquidRafId = requestAnimationFrame(animateLiquid);
  }
  if (turbulenceEl) liquidRafId = requestAnimationFrame(animateLiquid);

  // ── Cleanup ──────────────────────────────────────────────────────────────
  window.addEventListener("beforeunload", () => {
    if (liquidRafId  !== null) cancelAnimationFrame(liquidRafId);
    if (scrollRafId  !== null) cancelAnimationFrame(scrollRafId);
    if (currentVideo) { currentVideo.pause(); currentVideo.src = ""; }
  });
</script>

<style>
  /* Glass pill — liquid refraction only, no visible background */
  #glass-frame {
    opacity: 0;
    transition: opacity 220ms ease;
    backdrop-filter:
      url(#liquid-refraction-filter)
      blur(10px)
      contrast(1.04)
      brightness(1.1);
    -webkit-backdrop-filter:
      url(#liquid-refraction-filter)
      blur(10px)
      contrast(1.04)
      brightness(1.1);
  }

  /* Items — default dim state */
  :global(.cascade-item) {
    color: rgba(255,255,255,0.4);
  }

  /* Active item aligned behind the glass pill */
  :global(.cascade-item.is-centered) {
    color: rgba(255,255,255,0.95);
  }

  :global(.cascade-item.is-centered .cascade-title) {
    color: rgba(255,255,255,0.95);
  }

  :global(.cascade-item.is-centered .arrow-default) {
    opacity: 0;
  }

  :global(.cascade-item.is-centered .arrow-active) {
    opacity: 1;
  }
</style>
