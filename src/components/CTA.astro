<section class="cta-scroll" data-cta-section>
  <div class="cta-frame" data-cta-frame>
    <div class="cta-content-bg"></div>
    <div class="cta-grid" aria-hidden="true">
      <span class="cta-center-dot">
        <svg width="200" height="200" viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
          <circle fill="#ff0000" stroke="none" cx="60" cy="60" r="12">
            <animate attributeName="opacity" dur="1s" values="0;1;0" repeatCount="indefinite" begin="0.1" />
          </circle>
        </svg>
      </span>
      <span class="cta-icon-wrap cta-cell-top-left">
        <svg class="cta-icon" width="50" height="50" viewBox="0 0 50 50" xmlns="http://www.w3.org/2000/svg">
          <rect x="0" y="0" width="20" height="50" rx="2" fill="#fff"></rect>
          <rect x="0" y="0" width="50" height="20" rx="2" fill="#fff"></rect>
        </svg>
      </span>
      <span class="cta-icon-wrap cta-cell-top-right">
        <svg class="cta-icon" width="50" height="50" viewBox="0 0 50 50" xmlns="http://www.w3.org/2000/svg">
          <rect x="30" y="0" width="20" height="50" rx="2" fill="#fff"></rect>
          <rect x="0" y="0" width="50" height="20" rx="2" fill="#fff"></rect>
        </svg>
      </span>
      <span class="cta-icon-wrap cta-cell-bottom-left">
        <svg class="cta-icon" width="50" height="50" viewBox="0 0 50 50" xmlns="http://www.w3.org/2000/svg">
          <rect x="0" y="0" width="20" height="50" rx="2" fill="#fff"></rect>
          <rect x="0" y="30" width="50" height="20" rx="2" fill="#fff"></rect>
        </svg>
      </span>
      <span class="cta-icon-wrap cta-cell-bottom-right">
        <svg class="cta-icon" width="50" height="50" viewBox="0 0 50 50" xmlns="http://www.w3.org/2000/svg">
          <rect x="30" y="0" width="20" height="50" rx="2" fill="#fff"></rect>
          <rect x="0" y="30" width="50" height="20" rx="2" fill="#fff"></rect>
        </svg>
      </span>
    </div>
  </div>
</section>

<style>
  .cta-scroll {
    --enter-progress: 0;
    --split-progress: 0;
    --exit-offset: 0px;
    --piece-size: 50px;
    --piece-gap: 0.7rem;
    --frame-y: calc((1 - var(--enter-progress)) * 55vh);
    --frame-scale: calc(0.65 + var(--enter-progress) * 0.95);
    --piece-x: calc(var(--split-progress) * 15rem);
    --piece-y: calc(var(--split-progress) * 5rem);
    --icon-opacity: calc(0.22 + var(--enter-progress) * 0.78);
    height: 300vh;
    position: relative;
  }

  .cta-frame {
    position: fixed;
    left: 50%;
    top: 50%;
    transform: translate(-50%, calc(-50% + var(--frame-y) - var(--exit-offset))) scale(var(--frame-scale));
    transform-origin: center;
    will-change: transform;
    z-index: 20;
    pointer-events: none;
    visibility: hidden;
    animation: none !important;
  }

  .cta-scroll.is-active .cta-frame {
    visibility: visible;
  }

  .cta-grid {
    display: grid;
    grid-template-columns: repeat(2, var(--piece-size));
    grid-template-rows: repeat(2, var(--piece-size));
    gap: var(--piece-gap);
    position: relative;
  }

  .cta-content-bg {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: calc(2 * var(--piece-x) + 10px + var(--piece-gap));
    height: calc(2 * var(--piece-y) + 10px + var(--piece-gap));
    background: rgba(255, 255, 255, 0.06);
    border-radius: 4px;
    opacity: calc((var(--split-progress) - 0.7) * 3.33);
    pointer-events: none;
    backdrop-filter: blur(2px);
  }

  .cta-center-dot {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 1;
    opacity: calc(1 - var(--split-progress) * 5);
    pointer-events: none;
  }

  .cta-icon-wrap {
    width: var(--piece-size);
    height: var(--piece-size);
    display: inline-flex;
    opacity: var(--icon-opacity);
    will-change: transform;
  }

  .cta-cell-top-left {
    transform: translate(calc(-1 * var(--piece-x)), calc(-1 * var(--piece-y)));
  }

  .cta-cell-top-right {
    transform: translate(var(--piece-x), calc(-1 * var(--piece-y)));
  }

  .cta-cell-bottom-left {
    transform: translate(calc(-1 * var(--piece-x)), var(--piece-y));
  }

  .cta-cell-bottom-right {
    transform: translate(var(--piece-x), var(--piece-y));
  }

  .cta-icon {
    width: 100%;
    height: 100%;
    display: block;
    overflow: visible;
  }

  .cta-icon rect {
    fill: #fff !important;
    filter: drop-shadow(0 0 10px rgba(255, 255, 255, 0.35));
  }

  @media (max-width: 900px) {
    .cta-scroll {
      --piece-x: calc(var(--split-progress) * 11.4rem);
      --piece-y: calc(var(--split-progress) * 3.8rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cta-scroll {
      --enter-progress: 1;
      --split-progress: 1;
    }
  }
</style>

<script>
  const ctaSection = document.querySelector("[data-cta-section]");

  if (ctaSection instanceof HTMLElement) {
    const clamp = (value: number, min: number, max: number) =>
      Math.min(Math.max(value, min), max);
    const easeOutCubic = (t: number) => 1 - Math.pow(1 - t, 3);

    let targetEnter = 0;
    let targetSplit = 0;
    let currentEnter = 0;
    let currentSplit = 0;
    let rafId = 0;

    const updateTargets = () => {
      const rect = ctaSection.getBoundingClientRect();
      const vh = window.innerHeight || 1;

      const inView = rect.top < vh && rect.bottom > 0;
      ctaSection.classList.toggle("is-active", inView);

      const enterStart = vh * 0.6;
      const enterEnd = vh * 0.05;
      const enterRaw = (enterStart - rect.top) / (enterStart - enterEnd);
      targetEnter = easeOutCubic(clamp(enterRaw, 0, 1));

      const splitStartY = vh * 0.3;
      const splitEndY = vh * -0.49;
      const splitRaw = (splitStartY - rect.top) / (splitStartY - splitEndY);
      targetSplit = easeOutCubic(clamp(splitRaw, 0, 1));

      const exitPx = (targetSplit >= 0.999 && rect.bottom < vh)
        ? vh - rect.bottom
        : 0;
      ctaSection.style.setProperty("--exit-offset", `${exitPx}px`);

      if (!rafId) rafId = window.requestAnimationFrame(animate);
    };

    const animate = () => {
      const smoothing = 0.12;
      currentEnter += (targetEnter - currentEnter) * smoothing;
      currentSplit += (targetSplit - currentSplit) * smoothing;

      if (Math.abs(targetEnter - currentEnter) < 0.0005) currentEnter = targetEnter;
      if (Math.abs(targetSplit - currentSplit) < 0.0005) currentSplit = targetSplit;

      ctaSection.style.setProperty("--enter-progress", currentEnter.toFixed(4));
      ctaSection.style.setProperty("--split-progress", currentSplit.toFixed(4));

      if (currentEnter !== targetEnter || currentSplit !== targetSplit) {
        rafId = window.requestAnimationFrame(animate);
      } else {
        rafId = 0;
      }
    };

    updateTargets();
    window.addEventListener("scroll", updateTargets, { passive: true });
    window.addEventListener("resize", updateTargets);
  }
</script>