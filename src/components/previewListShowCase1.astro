---
const items = [
  {
    name: "PHOTOS",
    preview: "/anjunadeep.jpg",
    type: "image"
  },
  {
    name: "INTERVIEWS",
    preview: "/martin-garrix.mp4",
    type: "video"
  },
  {
    name: "SHOWS",
    preview: "/coldplay.jpg",
    type: "image"
  },
  {
    name: "ADVERTISMENTS",
    preview: "bryan-adams.png",
    type: "image"
  },
  {
    name: "SHORTFILMS",
    preview: "/klang-preview-3.jpg",
    type: "image"
  },
  {
    name: "MISC.",
    preview: "korolova.mp4",
    type: "video"
  },
];
---

<div
  id="preview-showcase-1"
  class="relative flex justify-center items-center bg-[#1c1c1c] w-full min-h-[100vh] h-[100vh] pb-3 overflow-hidden"
>
  <!-- Liquid Glass cursor -->
  <div
    id="glass-cursor"
    aria-hidden="true"
    class="pointer-events-none absolute top-0 left-0 z-30 w-[260px] h-[260px] rounded-full opacity-0 transition-opacity duration-300 will-change-transform"
    style="--mx:0.5;--my:0.5; transform: translate3d(-999px,-999px,0); backdrop-filter: blur(0.4px) saturate(180%) brightness(116%) contrast(108%); -webkit-backdrop-filter: blur(0.4px) saturate(180%) brightness(116%) contrast(108%);"
  >
    <!-- WebGL refraction canvas -->
    <canvas
      id="glass-lens"
      class="absolute inset-0 w-full h-full rounded-full"
    ></canvas>
    <!-- Dynamic specular (shifts with cursor) -->
    <div
      class="absolute inset-0 rounded-full"
      style="background: radial-gradient(circle at calc(28% + var(--mx)*16%) calc(22% + var(--my)*16%), rgba(255,255,255,0.5), rgba(255,255,255,0.06) 34%, transparent 56%); pointer-events:none;"
    ></div>
    <!-- Prismatic rim -->
    <div
      class="absolute inset-0 rounded-full"
      style="background: conic-gradient(from 200deg, rgba(255,70,70,0.1), rgba(255,175,45,0.08), rgba(240,240,80,0.06), rgba(70,230,120,0.06), rgba(70,170,255,0.1), rgba(130,70,255,0.12), rgba(255,70,170,0.1), rgba(255,70,70,0.1)); -webkit-mask: radial-gradient(circle, transparent 62%, black 86%); mask: radial-gradient(circle, transparent 62%, black 86%); pointer-events:none;"
    ></div>
    <!-- Rim border -->
    <div
      class="absolute inset-0 rounded-full"
      style="border:1.2px solid rgba(255,255,255,0.25); box-shadow: 0 12px 40px rgba(0,0,0,0.35); pointer-events:none;"
    ></div>
  </div>

  <!-- Background Preview Container -->
  <div id="preview-bg" class="absolute inset-0 will-change-contents">
    {items.filter(item => item.type === "video").map((item) => (
      <video
        data-video-src={item.preview}
        class="hidden w-full h-full object-cover"
        muted
        loop
        preload="metadata"
      >
        <source src={item.preview} type="video/mp4" />
      </video>
    ))}
    <div
      id="bg-image"
      class="absolute inset-0 transition-opacity duration-500 ease-in-out bg-cover bg-center"
      style={`background-image: url(${items[0].preview})`}
    ></div>
    <div id="bg-video-container" class="absolute inset-0 opacity-0 transition-opacity duration-500 ease-in-out"></div>
  </div>

  <div class="absolute inset-0 bg-black/60"></div>

  <!-- Main List -->
  <div class="flex flex-col justify-center items-center w-full h-[80vh] px-4 sm:px-6 md:px-8">
    <div class="z-10 w-full h-full flex flex-col justify-center items-center pt-8">
      <div class="z-20 w-full sm:w-4/5 md:w-3/5 lg:w-1/2 xl:w-[40%] flex h-[20%] justify-start items-end"></div>
      <div
        class="h-[60%] w-full sm:w-4/5 md:w-3/5 lg:w-1/2 xl:w-[40%] flex flex-col justify-start items-center"
        set:html={`
                     ${items
                       .map(
                         (item, idx) =>
                           `<div class="cascade-item h-[10vh] min-h-[56px] w-full border-t border-gray-400 flex flex-row justify-between items-center group relative overflow-hidden hover-bg-transition will-change-transform opacity-0 translate-y-6 transition-all duration-700 ease-out" data-preview="${item.preview}" data-type="${item.type}" style="display: flex; align-items: center; transition-delay: ${idx * 90}ms;">
                        <h2 class="pt-2 text-gray-400 group-hover:text-black cursor-pointer w-full text-3xl md:text-4xl font-black text-gray-100 origin-left transition-all duration-300 scale-x-125 hover:scale-x-150 will-change-transform" style="display: flex; justify-content: start; height: 100%; gap: 0.5rem;">
                          <span>(${String(idx + 1).padStart(3, "0")})</span>
                          <span>${item.name}</span>
                        </h2>
                        <div class="relative w-[28px] h-[28px] md:w-[32px] md:h-[32px]" style="display: flex; align-items: center; justify-content: center;">
                            <img src="/assets/up-right-arrow-gray.png" alt="${item.name}" width="32" height="32" class="w-[28px] h-[28px] md:w-[32px] md:h-[32px] object-cover transition-opacity duration-300 group-hover:opacity-0" style="filter: contrast(1.8) brightness(0.6) saturate(1.5);" loading="lazy" />
                            <img src="/assets/up-right-arrow-black.png" alt="${item.name}" width="32" height="32" class="w-[28px] h-[28px] md:w-[32px] md:h-[32px] object-cover absolute top-0 left-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300" style="filter: contrast(2.0) brightness(0.5) saturate(1.8);" loading="lazy" />
                        </div>
                    </div>`,
                       )
                       .join("")}
                        `}
      />
    </div>
  </div>
</div>

<script>
  const bgImage = document.getElementById("bg-image") as HTMLElement | null;
  const bgVideoContainer = document.getElementById("bg-video-container") as HTMLElement | null;
  const showcaseSection = document.getElementById("preview-showcase-1") as HTMLElement | null;
  const glassCursor = document.getElementById("glass-cursor") as HTMLElement | null;
  const lensCanvas = document.getElementById("glass-lens") as HTMLCanvasElement | null;
  const preloadedVideos = new Map<string, HTMLVideoElement>();

  document.querySelectorAll("[data-video-src]").forEach((video) => {
    const src = video.getAttribute("data-video-src");
    if (src && video instanceof HTMLVideoElement) {
      preloadedVideos.set(src, video);
    }
  });

  let currentVideo: HTMLVideoElement | null = null;
  let isTransitioning = false;
  let rafId: number | null = null;
  let activeVideoEl: HTMLVideoElement | null = null;

  const cursor = {
    curX: -999, curY: -999,
    tgtX: -999, tgtY: -999,
    bgCX: 0.5, bgCY: 0.5,
    tgtBgCX: 0.5, tgtBgCY: 0.5,
  };

  function debounce(func: (...args: any[]) => void, wait: number) {
    let timeout: ReturnType<typeof setTimeout> | undefined;
    return function executedFunction(...args: any[]) {
      clearTimeout(timeout);
      timeout = setTimeout(() => func(...args), wait);
    };
  }

  // ── WebGL Lens ──────────────────────────────────────────────

  let gl: WebGLRenderingContext | null = null;
  let lensTex: WebGLTexture | null = null;
  let uBgCenter: WebGLUniformLocation | null = null;
  const isTouchDevice = window.matchMedia("(pointer: coarse)").matches;

  const VERT = [
    "attribute vec2 a_pos;",
    "varying vec2 v_uv;",
    "void main(){",
    "  v_uv = a_pos * 0.5 + 0.5;",
    "  gl_Position = vec4(a_pos, 0.0, 1.0);",
    "}",
  ].join("\n");

  const FRAG = [
    "precision highp float;",
    "varying vec2 v_uv;",
    "uniform sampler2D u_tex;",
    "uniform vec2 u_bgCenter;",
    "",
    "void main(){",
    "  vec2 c = vec2(0.5);",
    "  vec2 d = v_uv - c;",
    "  float dist = length(d);",
    "",
    "  float mask = smoothstep(0.49, 0.44, dist);",
    "  if(mask < 0.001){ gl_FragColor = vec4(0.0); return; }",
    "",
    "  float r = clamp(dist / 0.44, 0.0, 1.0);",
    "",
    "  // sphere surface normal z-component",
    "  float nz = sqrt(max(0.0, 1.0 - r * r));",
    "",
    "  // refraction offset: physically based bend",
    "  float bend = r * (1.0 - nz) * 0.35;",
    "  vec2 dir = (dist > 0.001) ? d / dist : vec2(0.0);",
    "  vec2 offset = dir * bend;",
    "",
    "  // chromatic aberration — stronger toward edges",
    "  float ca = 0.045 * r * r;",
    "  vec2 base = u_bgCenter + offset;",
    "",
    "  float R = texture2D(u_tex, base - dir * ca).r;",
    "  float G = texture2D(u_tex, base).g;",
    "  float B = texture2D(u_tex, base + dir * ca * 1.4).b;",
    "  vec3 col = vec3(R, G, B);",
    "",
    "  col *= 0.88;",
    "",
    "  // fresnel — dark blue rim",
    "  float fresnel = pow(1.0 - nz, 2.0);",
    "  col = mix(col, vec3(0.01, 0.03, 0.14), fresnel * 0.88);",
    "",
    "  // specular highlight top-left",
    "  vec2 sp = d - vec2(-0.09, 0.11);",
    "  col += exp(-dot(sp, sp) * 100.0) * vec3(1.0) * 0.5;",
    "",
    "  // secondary specular bottom-right",
    "  vec2 sp2 = d - vec2(0.06, -0.14);",
    "  col += exp(-dot(sp2, sp2) * 260.0) * vec3(0.7, 0.75, 1.0) * 0.1;",
    "",
    "  // blue rim glow",
    "  float rim = smoothstep(0.34, 0.45, dist) * mask;",
    "  col += vec3(0.05, 0.09, 0.38) * rim * 0.4;",
    "",
    "  // transparent center → opaque edges (text readable at center)",
    "  float edgeFade = smoothstep(0.0, 0.38, dist);",
    "  float a = mask * mix(0.08, 1.0, edgeFade);",
    "  gl_FragColor = vec4(col * a, a);",
    "}",
  ].join("\n");

  function initLens(): boolean {
    if (!lensCanvas) return false;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    lensCanvas.width = 260 * dpr;
    lensCanvas.height = 260 * dpr;

    gl = lensCanvas.getContext("webgl", {
      premultipliedAlpha: false, alpha: true, antialias: true,
    });
    if (!gl) return false;

    function compile(src: string, type: number) {
      const s = gl!.createShader(type)!;
      gl!.shaderSource(s, src);
      gl!.compileShader(s);
      if (!gl!.getShaderParameter(s, gl!.COMPILE_STATUS)) {
        console.error("Shader error:", gl!.getShaderInfoLog(s));
        return null;
      }
      return s;
    }

    const vs = compile(VERT, gl.VERTEX_SHADER);
    const fs = compile(FRAG, gl.FRAGMENT_SHADER);
    if (!vs || !fs) return false;

    const prog = gl.createProgram()!;
    gl.attachShader(prog, vs);
    gl.attachShader(prog, fs);
    gl.linkProgram(prog);
    if (!gl.getProgramParameter(prog, gl.LINK_STATUS)) {
      console.error("Link error:", gl.getProgramInfoLog(prog));
      return false;
    }
    gl.useProgram(prog);

    const buf = gl.createBuffer();
    gl.bindBuffer(gl.ARRAY_BUFFER, buf);
    gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1,-1,1,-1,-1,1,1,1]), gl.STATIC_DRAW);
    const a = gl.getAttribLocation(prog, "a_pos");
    gl.enableVertexAttribArray(a);
    gl.vertexAttribPointer(a, 2, gl.FLOAT, false, 0, 0);

    lensTex = gl.createTexture();
    gl.bindTexture(gl.TEXTURE_2D, lensTex);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_S, gl.CLAMP_TO_EDGE);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_T, gl.CLAMP_TO_EDGE);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MIN_FILTER, gl.LINEAR);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MAG_FILTER, gl.LINEAR);
    gl.pixelStorei(gl.UNPACK_FLIP_Y_WEBGL, 1);

    gl.enable(gl.BLEND);
    gl.blendFunc(gl.SRC_ALPHA, gl.ONE_MINUS_SRC_ALPHA);

    uBgCenter = gl.getUniformLocation(prog, "u_bgCenter");
    return true;
  }

  function loadImageToLens(url: string) {
    if (!gl || !lensTex) return;
    activeVideoEl = null;
    const img = new Image();
    img.crossOrigin = "anonymous";
    img.onload = () => {
      gl!.bindTexture(gl!.TEXTURE_2D, lensTex);
      gl!.texImage2D(gl!.TEXTURE_2D, 0, gl!.RGBA, gl!.RGBA, gl!.UNSIGNED_BYTE, img);
    };
    img.src = url;
  }

  // ── Preview Switcher ────────────────────────────────────────

  function switchPreview(previewUrl: string, mediaType: string) {
    if (isTransitioning || !bgImage || !bgVideoContainer) return;
    isTransitioning = true;

    if (mediaType === "video") {
      let video = preloadedVideos.get(previewUrl);
      if (!video) {
        video = document.createElement("video");
        video.className = "w-full h-full object-cover";
        video.muted = true;
        video.loop = true;
        video.playsInline = true;
        const source = document.createElement("source");
        source.src = previewUrl;
        source.type = "video/mp4";
        video.appendChild(source);
        preloadedVideos.set(previewUrl, video);
      }
      if (currentVideo && currentVideo !== video) {
        currentVideo.pause();
        currentVideo.currentTime = 0;
      }
      bgVideoContainer.innerHTML = "";
      bgVideoContainer.appendChild(video.cloneNode(true) as HTMLVideoElement);
      const newVideo = bgVideoContainer.querySelector("video") as HTMLVideoElement | null;
      if (newVideo) {
        newVideo.play().catch(() => {});
        currentVideo = newVideo;
        activeVideoEl = newVideo;
      }
      bgImage.style.opacity = "0";
      bgVideoContainer.style.opacity = "1";
    } else {
      if (currentVideo) {
        currentVideo.pause();
        currentVideo.currentTime = 0;
      }
      activeVideoEl = null;
      bgImage.style.backgroundImage = `url(${previewUrl})`;
      bgVideoContainer.style.opacity = "0";
      bgImage.style.opacity = "1";
      loadImageToLens(previewUrl);
    }

    setTimeout(() => { isTransitioning = false; }, 100);
  }

  const debouncedSwitch = debounce(switchPreview, 50);

  document.querySelectorAll("[data-preview]").forEach((el) => {
    el.addEventListener("mouseenter", () => {
      const url = el.getAttribute("data-preview");
      const type = el.getAttribute("data-type");
      if (url && type) switchPreview(url, type);
    }, { passive: true });
  });

  // ── Cascade Observer ────────────────────────────────────────

  const listItems = document.querySelectorAll(".cascade-item");
  const sectionObserver = new IntersectionObserver(
    (entries, observer) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        listItems.forEach((item) => {
          item.classList.remove("opacity-0", "translate-y-6");
          item.classList.add("opacity-100", "translate-y-0");
        });
        observer.unobserve(entry.target);
      });
    },
    { threshold: 0.25 },
  );
  const listContainer = document.querySelector(".cascade-item")?.parentElement;
  if (listContainer) sectionObserver.observe(listContainer);

  // ── Glass Cursor Render Loop ────────────────────────────────

  function renderLens() {
    if (!gl || !lensCanvas || !uBgCenter || !glassCursor) return;

    cursor.curX += (cursor.tgtX - cursor.curX) * 0.12;
    cursor.curY += (cursor.tgtY - cursor.curY) * 0.12;
    cursor.bgCX += (cursor.tgtBgCX - cursor.bgCX) * 0.12;
    cursor.bgCY += (cursor.tgtBgCY - cursor.bgCY) * 0.12;

    glassCursor.style.transform =
      `translate3d(${cursor.curX}px, ${cursor.curY}px, 0)`;

    if (activeVideoEl && activeVideoEl.readyState >= 2) {
      gl.bindTexture(gl.TEXTURE_2D, lensTex);
      gl.texImage2D(gl.TEXTURE_2D, 0, gl.RGBA, gl.RGBA, gl.UNSIGNED_BYTE, activeVideoEl);
    }

    gl.uniform2f(uBgCenter, cursor.bgCX, cursor.bgCY);
    gl.viewport(0, 0, lensCanvas.width, lensCanvas.height);
    gl.clearColor(0, 0, 0, 0);
    gl.clear(gl.COLOR_BUFFER_BIT);
    gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4);

    rafId = requestAnimationFrame(renderLens);
  }

  if (showcaseSection && glassCursor && lensCanvas && !isTouchDevice && initLens()) {
    const initBg = bgImage?.style.backgroundImage?.match(
      /url\(["']?(.+?)["']?\)/,
    )?.[1];
    if (initBg) loadImageToLens(initBg);

    showcaseSection.addEventListener("mouseenter", () => {
      glassCursor.classList.remove("opacity-0");
      glassCursor.classList.add("opacity-100");
      if (rafId === null) rafId = requestAnimationFrame(renderLens);
    });

    showcaseSection.addEventListener("mousemove", (e) => {
      const rect = showcaseSection.getBoundingClientRect();
      const half = glassCursor.offsetWidth / 2;
      cursor.tgtX = e.clientX - rect.left - half;
      cursor.tgtY = e.clientY - rect.top - half;
      cursor.tgtBgCX = (e.clientX - rect.left) / rect.width;
      cursor.tgtBgCY = 1.0 - (e.clientY - rect.top) / rect.height;

      const nx = (e.clientX - rect.left) / rect.width;
      const ny = (e.clientY - rect.top) / rect.height;
      glassCursor.style.setProperty("--mx", String(nx));
      glassCursor.style.setProperty("--my", String(ny));
    });

    showcaseSection.addEventListener("mouseleave", () => {
      glassCursor.classList.remove("opacity-100");
      glassCursor.classList.add("opacity-0");
    });
  }

  // ── Cleanup ─────────────────────────────────────────────────

  window.addEventListener("beforeunload", () => {
    if (rafId !== null) cancelAnimationFrame(rafId);
    if (currentVideo) { currentVideo.pause(); currentVideo.src = ""; }
  });
</script>
